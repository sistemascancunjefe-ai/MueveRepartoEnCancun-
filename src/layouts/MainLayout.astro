---
import { ClientRouter } from 'astro:transitions';
import '../index.css';
import Toast from '../components/ui/Toast.astro';
import PwaReload from '../components/ui/PwaReload.astro';
import BottomNav from '../components/BottomNav.astro';
import BrandAnimation from '../components/ui/BrandAnimation.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  hideNav?: boolean;
}

const {
  title,
  description = "Gestiona tus entregas del día: paradas, ruta óptima y notificaciones al cliente.",
  image = "/og-image.png",
  hideNav = false
} = Astro.props;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Mueve Reparto",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any",
  "description": description,
  "url": Astro.url.href,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "MXN"
  },
  "areaServed": {
    "@type": "City",
    "name": "Cancún",
    "addressRegion": "Quintana Roo",
    "addressCountry": "MX"
  }
}).replace(/</g, '\\u003c');
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0" />

    <meta http-equiv="Content-Security-Policy" content="
        default-src 'self';
        script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://*.cartocdn.com https://*.openstreetmap.org https://js.stripe.com;
        style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
        img-src 'self' data: blob: https://*.cartocdn.com https://*.openstreetmap.org https://*.tile.openstreetmap.org;
        font-src 'self' https://fonts.gstatic.com;
        frame-src https://js.stripe.com https://hooks.stripe.com;
        connect-src 'self' https://*.cartocdn.com https://*.openstreetmap.org https://nominatim.openstreetmap.org https://mueve-reparto-api.onrender.com https://api.stripe.com;
        worker-src 'self' blob:;
        object-src 'none';
        base-uri 'self';
        upgrade-insecure-requests;
    ">

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Mueve Reparto</title>
    <meta name="description" content={description} />

    <meta name="geo.region" content="MX-ROO" />
    <meta name="geo.placename" content="Cancún" />
    <meta name="geo.position" content="21.1619;-86.8515" />
    <meta name="ICBM" content="21.1619, -86.8515" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={`${title} | Mueve Reparto`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site || Astro.url)} />
    <meta property="og:site_name" content="Mueve Reparto" />
    <meta property="og:locale" content="es_MX" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url.href} />
    <meta name="twitter:title" content={`${title} | Mueve Reparto`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site || Astro.url)} />

    <script type="application/ld+json" set:html={jsonLd} />

    <meta name="theme-color" content="#00E8A2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0F172A" media="(prefers-color-scheme: dark)" />

    <meta name="theme-color" content="#00E8A2" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/pwa-192x192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }

      (function() {
        const stored = localStorage.getItem('mr-theme');
        if (stored === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
          if (!stored) localStorage.setItem('mr-theme', 'dark');
        }
      })();
    </script>

    <slot name="head" />
    <ClientRouter />
  </head>

  <body id="top" class="min-h-screen antialiased" style="background: var(--surface-bg); color: var(--text-primary);">

    {!hideNav && (
    <header class="fixed top-0 left-0 right-0 z-40 h-14 px-4 flex items-center justify-between app-header">
      <a href="/home" class="flex items-center gap-2 no-underline outline-none" aria-label="Mueve Reparto — Inicio">
        <BrandAnimation />
      </a>

      <div class="flex items-center gap-2">
        <div id="gps-indicator" class="hidden items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold"
             style="background: rgba(0,232,162,0.12); color: var(--color-primary);">
          <span class="gps-pulse inline-block w-2 h-2 rounded-full" style="background: var(--color-primary);"></span>
          GPS
        </div>

        <a id="plan-badge-btn" href="/suscripcion"
           class="hidden items-center px-2 py-1 rounded-full text-xs font-bold no-underline"
           style="color: var(--text-secondary); border: 1px solid var(--border-light); background: var(--surface-elevated);"
           aria-label="Mi plan">
          <span id="plan-badge-text">Free</span>
        </a>

        <a href="/perfil" id="repartidor-btn"
                class="flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold transition-all no-underline"
                style="background: var(--surface-input); color: var(--text-secondary);"
                aria-label="Ir a perfil">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
          </svg>
          <span id="repartidor-name">Repartidor</span>
        </a>

        <button class="theme-toggle w-8 h-8 rounded-xl flex items-center justify-center transition-all"
                style="color: var(--text-secondary);"
                aria-label="Cambiar tema">
          <svg class="dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-2.98 0-5.4-2.42-5.4-5.4 0-1.81.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"/>
          </svg>
          <svg class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 00-1.41 0 .996.996 0 000 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 00-1.41 0 .996.996 0 000 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96a.996.996 0 000-1.41.996.996 0 00-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36a.996.996 0 000-1.41.996.996 0 00-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
          </svg>
        </button>
      </div>
    </header>
    )}

    <main class:list={[
      'w-full mx-auto',
      !hideNav && 'pt-14 pb-20'
    ]} style="max-width: 480px;">
      <slot />
    </main>

    {!hideNav && <BottomNav />}

    <Toast />
    <PwaReload />

    <!-- Freemium Gate -->
    <div id="freemium-gate" role="dialog" aria-modal="true" aria-label="Plan Freemium"
         style="display:none;position:fixed;inset:0;z-index:9999;
                background:rgba(6,10,14,0.97);backdrop-filter:blur(8px);
                flex-direction:column;align-items:center;justify-content:center;
                padding:1.5rem;text-align:center;overflow-y:auto;">
      <div style="max-width:360px;width:100%;padding:1rem 0;">
        <div style="width:64px;height:64px;border-radius:18px;background:rgba(0,232,162,0.1);
                    border:1px solid rgba(0,232,162,0.25);display:flex;align-items:center;
                    justify-content:center;margin:0 auto 1.125rem;">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="#00E8A2" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        </div>
        <div style="display:inline-block;padding:0.25rem 0.75rem;border-radius:99px;
                    background:rgba(0,232,162,0.08);border:1px solid rgba(0,232,162,0.2);
                    font-size:0.625rem;font-weight:800;color:#00E8A2;
                    text-transform:uppercase;letter-spacing:0.12em;margin-bottom:0.875rem;">
          Versión básica activa
        </div>
        <h2 style="font-size:1.375rem;font-weight:900;color:#E2E8F0;margin:0 0 0.5rem;letter-spacing:-0.03em;">
          Periodo de prueba<br>finalizado
        </h2>
        <p style="font-size:0.8125rem;color:#64748B;margin:0 0 1.5rem;line-height:1.6;">
          Llevas <strong id="freemium-days-used" style="color:#E2E8F0;">0</strong> días usando Mueve Reparto.
          La versión básica limita a <strong style="color:#FF5A5F;">5 paradas</strong> activas.
        </p>
        <div style="background:linear-gradient(135deg,rgba(0,232,162,0.07) 0%,rgba(13,17,23,0.9) 100%);
                    border:1px solid rgba(0,232,162,0.2);border-radius:14px;padding:1rem;margin-bottom:0.875rem;">
          <div style="font-size:1.625rem;font-weight:900;color:#00E8A2;margin-bottom:0.25rem;">$99
            <span style="font-size:0.875rem;font-weight:600;color:#64748B;">MXN/mes</span>
          </div>
          <div style="font-size:0.75rem;color:#64748B;margin-bottom:0.75rem;">Mueve Reparto Pro — cancela cuando quieras</div>
          <ul style="list-style:none;padding:0;margin:0 0 0.875rem;text-align:left;display:flex;flex-direction:column;gap:0.3rem;">
            <li style="font-size:0.8125rem;color:#94A3B8;display:flex;align-items:center;gap:0.5rem;"><svg width="13" height="13" viewBox="0 0 24 24" fill="#00E8A2"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Paradas ilimitadas</li>
            <li style="font-size:0.8125rem;color:#94A3B8;display:flex;align-items:center;gap:0.5rem;"><svg width="13" height="13" viewBox="0 0 24 24" fill="#00E8A2"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Dashboard KPIs avanzado</li>
            <li style="font-size:0.8125rem;color:#94A3B8;display:flex;align-items:center;gap:0.5rem;"><svg width="13" height="13" viewBox="0 0 24 24" fill="#00E8A2"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Registro de gasolina</li>
            <li style="font-size:0.8125rem;color:#94A3B8;display:flex;align-items:center;gap:0.5rem;"><svg width="13" height="13" viewBox="0 0 24 24" fill="#00E8A2"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>Historial completo 90 días</li>
          </ul>
          <a href="/suscripcion" id="freemium-cta"
             style="display:block;width:100%;padding:0.8125rem;
                    background:linear-gradient(135deg,#00E8A2,#00C48C);
                    color:#060A0E;font-weight:900;font-size:0.9375rem;
                    border-radius:10px;text-decoration:none;text-align:center;">
            Suscribirme ahora
          </a>
        </div>
        <button id="freemium-continue-btn"
                style="background:transparent;border:1px solid #1E293B;color:#64748B;
                       font-size:0.8125rem;font-weight:600;padding:0.75rem 1.5rem;
                       border-radius:10px;cursor:pointer;width:100%;pointer-events:none;opacity:0.4;">
          Continuar con versión básica
          <span id="freemium-countdown">&nbsp;(<span id="freemium-secs">8</span>s)</span>
        </button>
      </div>
    </div>

    <!-- Onboarding -->
    <div id="onboarding-overlay" role="dialog" aria-modal="true" aria-label="Bienvenida a Mueve Reparto"
         style="display:none;position:fixed;inset:0;z-index:9998;
                background:rgba(6,10,14,0.96);backdrop-filter:blur(6px);
                flex-direction:column;align-items:center;justify-content:center;padding:1.5rem;">
      <div style="max-width:360px;width:100%;">
        <div id="ob-dots" style="display:flex;gap:0.375rem;justify-content:center;margin-bottom:1.75rem;"></div>
        <div id="ob-content" style="text-align:center;min-height:200px;"></div>
        <div id="ob-input-container" style="display:none;margin-top:1rem;">
           <input id="ob-name-input" type="text" class="input" placeholder="¿Cómo te llamas?" maxlength="24" style="text-align:center;font-size:1.125rem;" />
        </div>
        <div style="display:flex;gap:0.625rem;margin-top:1.5rem;">
          <button id="ob-skip" style="flex:1;padding:0.75rem;background:transparent;border:1px solid #1E293B;
                                       color:#64748B;font-size:0.8125rem;font-weight:600;border-radius:10px;cursor:pointer;">
            Saltar
          </button>
          <button id="ob-next" style="flex:2;padding:0.75rem;
                                       background:linear-gradient(135deg,#00E8A2,#00C48C);
                                       color:#060A0E;font-size:0.9375rem;font-weight:900;
                                       border-radius:10px;cursor:pointer;border:none;">
            Siguiente →
          </button>
        </div>
      </div>
    </div>

    <!-- PWA Install Banner -->
    <div id="pwa-install-banner"
         style="display:none;position:fixed;
                bottom:calc(var(--bottom-nav-h, 56px) + env(safe-area-inset-bottom) + 0.75rem);
                left:0.75rem;right:0.75rem;z-index:500;
                background:var(--surface-elevated,#161B22);
                border:1px solid rgba(0,232,162,0.25);border-radius:16px;
                padding:0.875rem 1rem;box-shadow:0 4px 24px rgba(0,0,0,0.4);">
      <div style="display:flex;align-items:center;gap:0.75rem;">
        <div style="width:40px;height:40px;border-radius:10px;background:rgba(0,232,162,0.1);
                    display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <img src="/icons/pwa-192x192.png" alt="" style="width:24px;height:24px;" />
        </div>
        <div style="flex:1;">
          <p style="font-size:0.8125rem;font-weight:800;color:#E2E8F0;margin:0;">
            Instala la app
          </p>
          <p style="font-size:0.6875rem;color:#64748B;margin:0;">
            Sin internet · acceso rápido desde inicio
          </p>
        </div>
        <button id="pwa-install-btn"
                style="padding:0.5rem 0.875rem;background:linear-gradient(135deg,#00E8A2,#00C48C);
                       color:#060A0E;font-size:0.8125rem;font-weight:900;border:none;
                       border-radius:8px;cursor:pointer;flex-shrink:0;">
          Instalar
        </button>
        <button id="pwa-install-dismiss"
                style="padding:0.5rem;background:transparent;border:1px solid #1E293B;
                       color:#64748B;border-radius:8px;cursor:pointer;line-height:1;flex-shrink:0;"
                aria-label="Cerrar">✕</button>
      </div>
    </div>

    <script>
      import { initSyncManager } from '../lib/sync'
      import { setupTooltips } from '../utils/tooltips.js';

      function setupTheme() {
        document.querySelectorAll('.theme-toggle').forEach(btn => {
          const fresh = btn.cloneNode(true);
          btn.parentNode.replaceChild(fresh, btn);
          fresh.addEventListener('click', () => {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('mr-theme', isDark ? 'dark' : 'light');
          });
        });
      }

      function setupRepartidorName() {
        const name = localStorage.getItem('mr-repartidor-name') || 'Repartidor';
        const nameEl = document.getElementById('repartidor-name');
        if (nameEl) nameEl.textContent = name;
      }

      function setupPlanBadge() {
        const token = localStorage.getItem('mr-auth-token');
        const plan  = localStorage.getItem('mr-plan');
        const badge = document.getElementById('plan-badge-btn');
        const text  = document.getElementById('plan-badge-text');
        if (!badge || !text) return;
        if (token && plan) {
          badge.classList.replace('hidden', 'flex');
          if (plan === 'pro') {
            text.textContent = 'Pro';
            badge.style.background = 'rgba(0,232,162,0.12)';
            badge.style.color      = 'var(--color-primary)';
            badge.style.border     = '1px solid rgba(0,232,162,0.3)';
          } else {
            text.textContent = 'Free';
            badge.style.background = 'var(--surface-elevated)';
            badge.style.color      = 'var(--text-tertiary)';
            badge.style.border     = '1px solid var(--border-light)';
          }
        }
      }

      function setupFreemiumGate() {
        const INSTALL_KEY  = 'mr-install-date';
        const TRIAL_DAYS   = 31;
        const SKIP_PAGES   = ['/suscripcion', '/auth', '/offline', '/404'];

        if (!localStorage.getItem(INSTALL_KEY)) {
          localStorage.setItem(INSTALL_KEY, String(Date.now()));
        }

        const installDate = parseInt(localStorage.getItem(INSTALL_KEY), 10);
        const daysUsed    = Math.floor((Date.now() - installDate) / 86400000);
        const isPro       = localStorage.getItem('mr-plan') === 'pro';
        const path        = window.location.pathname;

        if (isPro || daysUsed <= TRIAL_DAYS || SKIP_PAGES.some(p => path.startsWith(p))) return;

        const gate     = document.getElementById('freemium-gate');
        const daysEl   = document.getElementById('freemium-days-used');
        const contBtn  = document.getElementById('freemium-continue-btn');
        const secsEl   = document.getElementById('freemium-secs');
        if (!gate) return;

        if (daysEl) daysEl.textContent = String(daysUsed);
        gate.style.display = 'flex';
        document.body.style.overflow = 'hidden';

        let secs = 8;
        const timer = setInterval(() => {
          secs--;
          if (secsEl) secsEl.textContent = String(secs);
          if (secs <= 0) {
            clearInterval(timer);
            if (contBtn) {
              contBtn.style.pointerEvents = 'auto';
              contBtn.style.opacity       = '1';
              const countdown = document.getElementById('freemium-countdown');
              if (countdown) countdown.style.display = 'none';
            }
          }
        }, 1000);

        if (contBtn) {
          contBtn.addEventListener('click', () => {
            gate.style.display = 'none';
            document.body.style.overflow = '';
          });
        }
      }

      const OB_STEPS = [
        {
          icon: '👋',
          title: '¡Bienvenido Repartidor!',
          body:  'Antes de empezar, dinos cómo te gustaría que te llamemos.',
          type:  'name',
          cta:   'Continuar →',
        },
        {
          icon: '📍',
          title: 'Agrega tus paradas',
          body:  'Escribe la dirección, escanea un QR o extrae texto de una foto (OCR). ¡Rápido y fácil!',
          cta:   'Siguiente →',
        },
        {
          icon: '🗺️',
          title: 'Optimiza tu ruta',
          body:  'En la sección "Ruta" presiona "Optimizar" para recorrer menos kilómetros y ahorrar gasolina.',
          cta:   'Siguiente →',
        },
        {
          icon: '💬',
          title: 'Avisa a tus clientes',
          body:  'Notifica por WhatsApp con un toque. Evita esperas y mejora tu servicio.',
          cta:   '¡Empezar! 🚚',
        },
      ];

      function setupOnboarding() {
        if (localStorage.getItem('mr-onboarded')) return;
        if (!['/', '/home'].includes(window.location.pathname)) return;

        const overlay   = document.getElementById('onboarding-overlay');
        const dotsEl    = document.getElementById('ob-dots');
        const contentEl = document.getElementById('ob-content');
        const nextBtn   = document.getElementById('ob-next');
        const skipBtn   = document.getElementById('ob-skip');
        const inputCont = document.getElementById('ob-input-container');
        const nameInput = document.getElementById('ob-name-input');
        if (!overlay || !dotsEl || !contentEl || !nextBtn || !skipBtn || !inputCont || !nameInput) return;

        let step = 0;

        function renderStep(i) {
          const s = OB_STEPS[i];
          dotsEl.innerHTML = OB_STEPS.map((_, idx) =>
            `<div style="width:${idx===i?'20px':'8px'};height:8px;border-radius:99px;
                         background:${idx===i?'#00E8A2':'#1E293B'};
                         transition:all 0.3s;"></div>`
          ).join('');
          contentEl.innerHTML = `
            <div style="font-size:3.5rem;margin-bottom:1rem;">${s.icon}</div>
            <h3 style="font-size:1.25rem;font-weight:900;color:#E2E8F0;margin:0 0 0.75rem;letter-spacing:-0.02em;">${s.title}</h3>
            <p style="font-size:0.875rem;color:#64748B;line-height:1.65;margin:0;">${s.body}</p>
          `;
          inputCont.style.display = s.type === 'name' ? 'block' : 'none';
          nextBtn.textContent = s.cta;
          skipBtn.style.display = i === OB_STEPS.length - 1 ? 'none' : 'block';
          if (s.type === 'name') setTimeout(() => nameInput.focus(), 500);
        }

        function closeOnboarding() {
          localStorage.setItem('mr-onboarded', '1');
          overlay.style.display = 'none';
          document.body.style.overflow = '';
          window.dispatchEvent(new CustomEvent('mr:onboarding-complete'));
        }

        renderStep(0);
        overlay.style.display = 'flex';
        document.body.style.overflow = 'hidden';

        nextBtn.addEventListener('click', () => {
          if (OB_STEPS[step].type === 'name') {
             const val = (nameInput as HTMLInputElement).value.trim();
             if (val) {
               localStorage.setItem('mr-repartidor-name', val);
               const nameEl = document.getElementById('repartidor-name');
               if (nameEl) nameEl.textContent = val;
             }
          }
          step++;
          if (step >= OB_STEPS.length) { closeOnboarding(); return; }
          renderStep(step);
        });
        skipBtn.addEventListener('click', closeOnboarding);
      }

      function setupPwaBanner() {
        const banner      = document.getElementById('pwa-install-banner');
        const installBtn  = document.getElementById('pwa-install-btn');
        const dismissBtn  = document.getElementById('pwa-install-dismiss');
        if (!banner || !installBtn || !dismissBtn) return;

        let _deferredInstall = null;
        window.addEventListener('beforeinstallprompt', (e) => {
          e.preventDefault();
          _deferredInstall = e;
          const dismisses = parseInt(localStorage.getItem('mr-install-dismissed') ?? '0', 10);
          if (dismisses >= 2) return;
          setTimeout(() => {
            if (banner) banner.style.display = 'block';
          }, 3000);
        });

        installBtn.addEventListener('click', async () => {
          if (!_deferredInstall) return;
          _deferredInstall.prompt();
          const result = await _deferredInstall.userChoice;
          if (result.outcome === 'accepted') {
            localStorage.setItem('mr-install-dismissed', '99');
          }
          banner.style.display = 'none';
          _deferredInstall = null;
        });

        dismissBtn.addEventListener('click', () => {
          banner.style.display = 'none';
          const d = parseInt(localStorage.getItem('mr-install-dismissed') ?? '0', 10) + 1;
          localStorage.setItem('mr-install-dismissed', String(d));
        });
      }

      function runAll() {
        initSyncManager();
        setupTheme();
        setupRepartidorName();
        setupPlanBadge();
        setupFreemiumGate();
        setupOnboarding();
        setupPwaBanner();
        setupTooltips();
      }

      document.addEventListener('astro:page-load', runAll);
      if (document.readyState !== 'loading') runAll();
    </script>
  </body>
</html>
