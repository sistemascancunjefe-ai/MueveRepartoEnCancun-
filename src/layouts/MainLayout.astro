---
import { ClientRouter } from 'astro:transitions';
import '../index.css';
import Toast from '../components/ui/Toast.astro';
import PwaReload from '../components/ui/PwaReload.astro';
import BottomNav from '../components/BottomNav.astro';
import BrandAnimation from '../components/ui/BrandAnimation.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  hideNav?: boolean;
}

const {
  title,
  description = "Gestiona tus entregas del día: paradas, ruta óptima y notificaciones al cliente.",
  image = "/og-image.png",
  hideNav = false
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0" />

    <!-- CSP -->
    <meta http-equiv="Content-Security-Policy" content="
        default-src 'self';
        script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://*.cartocdn.com https://*.openstreetmap.org;
        style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
        img-src 'self' data: blob: https://*.cartocdn.com https://*.openstreetmap.org https://*.tile.openstreetmap.org;
        font-src 'self' https://fonts.gstatic.com;
        connect-src 'self' https://*.cartocdn.com https://*.openstreetmap.org https://nominatim.openstreetmap.org https://mueve-reparto-api.onrender.com;
        worker-src 'self' blob:;
        object-src 'none';
        base-uri 'self';
        upgrade-insecure-requests;
    ">

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Mueve Reparto</title>
    <meta name="description" content={description} />

    <!-- Geo Tags (Cancún) -->
    <meta name="geo.region" content="MX-ROO" />
    <meta name="geo.placename" content="Cancún" />
    <meta name="geo.position" content="21.1619;-86.8515" />
    <meta name="ICBM" content="21.1619, -86.8515" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={`${title} | Mueve Reparto`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site || Astro.url)} />
    <meta property="og:site_name" content="Mueve Reparto" />
    <meta property="og:locale" content="es_MX" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={`${title} | Mueve Reparto`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site || Astro.url)} />

    <!-- Schema.org SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "Mueve Reparto",
      "applicationCategory": "BusinessApplication",
      "operatingSystem": "Any",
      "description": description,
      "url": Astro.url.href,
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "MXN"
      },
      "areaServed": {
        "@type": "City",
        "name": "Cancún",
        "addressRegion": "Quintana Roo",
        "addressCountry": "MX"
      }
    })} />

    <meta name="theme-color" content="#00E8A2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0F172A" media="(prefers-color-scheme: dark)" />

    <!-- PWA -->
    <meta name="theme-color" content="#00E8A2" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icons/pwa-192x192.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Service Worker -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }

      // Theme: dark-first for delivery workers
      (function() {
        const stored = localStorage.getItem('mr-theme');
        if (stored === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          // Default to dark
          document.documentElement.classList.add('dark');
          if (!stored) localStorage.setItem('mr-theme', 'dark');
        }
      })();
    </script>

    <ClientRouter />
  </head>

  <!-- Sync manager: IDB → API cuando hay conexión. No-op si PUBLIC_API_URL no está configurado -->
  <script>
    import { initSyncManager } from '@lib/sync'
    document.addEventListener('astro:page-load', initSyncManager, { once: true })
  </script>

  <body id="top" class="min-h-screen antialiased" style="background: var(--surface-bg); color: var(--text-primary);">

    <!-- ═══ Header ═══ -->
    {!hideNav && (
    <header class="fixed top-0 left-0 right-0 z-40 h-14 px-4 flex items-center justify-between app-header">

      <!-- Brand -->
      <a href="/home" class="flex items-center gap-2 no-underline outline-none" aria-label="Mueve Reparto — Inicio">
        <BrandAnimation />
      </a>

      <!-- Right Controls -->
      <div class="flex items-center gap-2">

        <!-- GPS indicator (shown when tracking is active) -->
        <div id="gps-indicator" class="hidden items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold"
             style="background: rgba(0,232,162,0.12); color: var(--color-primary);">
          <span class="gps-pulse inline-block w-2 h-2 rounded-full" style="background: var(--color-primary);"></span>
          GPS
        </div>

        <!-- Plan badge (visible cuando hay sesión activa) -->
        <a id="plan-badge-btn" href="/suscripcion"
           class="hidden items-center px-2 py-1 rounded-full text-xs font-bold no-underline"
           style="color: var(--text-secondary); border: 1px solid var(--border-light); background: var(--surface-elevated);"
           aria-label="Mi plan">
          <span id="plan-badge-text">Free</span>
        </a>

        <!-- Repartidor name badge -->
        <button id="repartidor-btn"
                class="flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold transition-all"
                style="background: var(--surface-input); color: var(--text-secondary);"
                aria-label="Nombre del repartidor">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
          </svg>
          <span id="repartidor-name">Repartidor</span>
        </button>

        <!-- Theme toggle -->
        <button class="theme-toggle w-8 h-8 rounded-xl flex items-center justify-center transition-all"
                style="color: var(--text-secondary);"
                aria-label="Cambiar tema">
          <!-- Moon (shown in light mode to switch to dark) -->
          <svg class="dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-2.98 0-5.4-2.42-5.4-5.4 0-1.81.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"/>
          </svg>
          <!-- Sun (shown in dark mode to switch to light) -->
          <svg class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58a.996.996 0 00-1.41 0 .996.996 0 000 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37a.996.996 0 00-1.41 0 .996.996 0 000 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96a.996.996 0 000-1.41.996.996 0 00-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36a.996.996 0 000-1.41.996.996 0 00-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>
          </svg>
        </button>
      </div>
    </header>
    )}

    <!-- ═══ Main Content ═══ -->
    <main class:list={[
      'w-full mx-auto',
      !hideNav && 'pt-14 pb-20'
    ]} style="max-width: 480px;">
      <slot />
    </main>

    <!-- ═══ Bottom Nav ═══ -->
    {!hideNav && <BottomNav />}

    <Toast />
    <PwaReload />

    <!-- Repartidor name modal -->
    <div id="name-modal-overlay" class="bottom-sheet-overlay" aria-hidden="true">
      <div id="name-modal" class="bottom-sheet" role="dialog" aria-label="Configurar nombre">
        <div class="sheet-handle"></div>
        <h2 style="font-size:1.125rem;font-weight:800;color:var(--text-primary);margin:0 0 0.25rem;">
          Tu nombre
        </h2>
        <p style="font-size:0.8125rem;color:var(--text-secondary);margin:0 0 1.25rem;">
          Se muestra en el header para identificarte
        </p>
        <input id="name-input" type="text" class="input" placeholder="Ej: Carlos, Juan..." maxlength="24" />
        <button id="name-save" class="btn-primary btn-lg w-full mt-3" style="width:100%;">
          Guardar
        </button>
      </div>
    </div>

    <script>
      import { setupTheme } from '@utils/theme';

      document.addEventListener('astro:page-load', setupTheme);

      if (document.readyState !== 'loading') {
        setupTheme();
      } else {
        window.addEventListener('DOMContentLoaded', setupTheme);
      }
    </script>
    <script is:inline>
      // Repartidor name
      function setupRepartidorName() {
        const name = localStorage.getItem('mr-repartidor-name') || 'Repartidor';
        const nameEl = document.getElementById('repartidor-name');
        if (nameEl) nameEl.textContent = name;

        const btn = document.getElementById('repartidor-btn');
        const overlay = document.getElementById('name-modal-overlay');
        const modal = document.getElementById('name-modal');
        const input = document.getElementById('name-input');
        const save = document.getElementById('name-save');

        if (!btn || !overlay || !modal || !input || !save) return;

        btn.addEventListener('click', () => {
          input.value = localStorage.getItem('mr-repartidor-name') || '';
          overlay.classList.add('open');
          modal.classList.add('open');
          overlay.setAttribute('aria-hidden', 'false');
          setTimeout(() => input.focus(), 400);
        });

        overlay.addEventListener('click', (e) => {
          if (e.target === overlay) closeNameModal();
        });

        save.addEventListener('click', () => {
          const val = input.value.trim();
          if (val) {
            localStorage.setItem('mr-repartidor-name', val);
            if (nameEl) nameEl.textContent = val;
          }
          closeNameModal();
        });

        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') save.click();
        });

        function closeNameModal() {
          overlay.classList.remove('open');
          modal.classList.remove('open');
          overlay.setAttribute('aria-hidden', 'true');
        }
      }

      // Plan badge
      function setupPlanBadge() {
        const token = localStorage.getItem('mr-auth-token');
        const plan  = localStorage.getItem('mr-plan');
        const badge = document.getElementById('plan-badge-btn');
        const text  = document.getElementById('plan-badge-text');
        if (!badge || !text) return;
        if (token && plan) {
          badge.classList.replace('hidden', 'flex');
          if (plan === 'pro') {
            text.textContent = 'Pro';
            badge.style.background = 'rgba(0,232,162,0.12)';
            badge.style.color      = 'var(--color-primary)';
            badge.style.border     = '1px solid rgba(0,232,162,0.3)';
          } else {
            text.textContent = 'Free';
            badge.style.background = 'var(--surface-elevated)';
            badge.style.color      = 'var(--text-tertiary)';
            badge.style.border     = '1px solid var(--border-light)';
          }
        }
      }

      // GPS indicator
      window.addEventListener('mr:tracking-start', () => {
        const el = document.getElementById('gps-indicator');
        if (el) el.classList.replace('hidden', 'flex');
      });
      window.addEventListener('mr:tracking-stop', () => {
        const el = document.getElementById('gps-indicator');
        if (el) el.classList.replace('flex', 'hidden');
      });

      document.addEventListener('astro:page-load', () => {
        setupRepartidorName();
        setupPlanBadge();
      });

      if (document.readyState !== 'loading') {
        setupRepartidorName();
        setupPlanBadge();
      } else {
        window.addEventListener('DOMContentLoaded', () => {
          setupRepartidorName();
          setupPlanBadge();
        });
      }
    </script>
  </body>
</html>
