---
interface Props {
  name: string;
  label: string;
  options: { value: string; label: string; icon?: string }[];
  placeholder?: string;
}

const { name, label, options, placeholder = "Selecciona una opción..." } = Astro.props;
---

<div class="graffiti-select-wrapper">
  <label for={`select-${name}`} class="select-label">{label}</label>

  <div class="select-container">
    <select name={name} id={`select-${name}`} class="native-select" required>
      <option value="" disabled selected hidden>{placeholder}</option>
      {options.map((opt) => (
        <option value={opt.value}>
          {opt.icon ? `${opt.icon} ${opt.label}` : opt.label}
        </option>
      ))}
    </select>
    <span class="chevron" aria-hidden="true">▼</span>
  </div>
</div>

<style>
  /*
   * GRAFFITI WARRIOR STYLE: CSS5
   * No Tailwind here. Just pure, unadulterated CSS logic.
   * Ah, perro! Usando native <select> con CSS moderno.
   */

  .graffiti-select-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    font-family: 'Atkinson', sans-serif; /* Project font */
    width: 100%;

    .select-label {
      font-size: 0.875rem;
      font-weight: 600;
      color: #334155; /* slate-700 */
    }

    .select-container {
      position: relative;
      display: flex;
      align-items: center;

      /* Custom chevron logic */
      .chevron {
        position: absolute;
        right: 1rem;
        pointer-events: none;
        font-size: 0.75rem;
        color: #64748b; /* slate-500 */
        opacity: 0.7;
        transition: transform 0.2s;
      }

      /* Rotate chevron when select is focused */
      &:has(.native-select:focus) .chevron {
        transform: rotate(180deg);
        color: #f97316; /* primary-500 */
      }
    }

    .native-select {
      /* base-select appearance for modern customizable selects where supported */
      appearance: base-select;
      /* fallback for regular appearance reset */
      -webkit-appearance: none;
      -moz-appearance: none;

      width: 100%;
      padding: 0.75rem 2.5rem 0.75rem 1rem; /* Extra padding right for the chevron */
      background-color: white;
      border: 1px solid #cbd5e1; /* slate-300 */
      border-radius: 0.5rem;
      font-size: 1rem;
      color: #1e293b; /* slate-800 */
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: inherit;

      /* When empty/placeholder is selected, make text lighter */
      &:invalid {
        color: #64748b; /* slate-500 */
      }

      &:hover {
        border-color: #94a3b8; /* slate-400 */
      }

      &:focus-visible {
        outline: 2px solid #f97316; /* primary-500 */
        outline-offset: 2px;
        border-color: #f97316;
      }

      /* For browsers that support ::picker(select) (CSS Custom Select API) */
      &::picker(select) {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        padding: 0.25rem;
      }

      /* Style options if supported */
      option {
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        color: #1e293b;
        background-color: white;

        &:checked {
          background-color: #f1f5f9; /* slate-100 */
          color: #f97316; /* primary-500 */
          font-weight: 600;
        }
      }
    }
  }
</style>
