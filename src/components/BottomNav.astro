---
const pathname = Astro.url.pathname;

const navItems = [
  {
    href: '/home',
    label: 'Inicio',
    activePattern: /^\/home/,
    icon: 'home',
  },
  {
    href: '/pedidos',
    label: 'Paradas',
    activePattern: /^\/pedidos/,
    icon: 'pin',
  },
  {
    href: '/reparto',
    label: 'Ruta',
    activePattern: /^\/reparto/,
    icon: 'route',
  },
  {
    href: '/enviar',
    label: 'Notificar',
    activePattern: /^\/enviar/,
    icon: 'send',
  },
  {
    href: '/metricas',
    label: 'Métricas',
    activePattern: /^\/metricas/,
    icon: 'chart',
  },
];
---

<nav transition:persist class="mr-nav" aria-label="Navegación principal">
  <div class="mr-nav-inner">
    {navItems.map((item) => {
      const isActive = item.activePattern.test(pathname);
      return (
        <a
          href={item.href}
          class={`mr-nav-item ${isActive ? 'active' : ''}`}
          aria-label={item.label}
          aria-current={isActive ? 'page' : undefined}
        >
          {isActive && <div class="mr-nav-pill" transition:name="nav-indicator" />}

          <div class={`mr-nav-icon-wrap ${isActive ? 'active' : ''}`}>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              {item.icon === 'home' && (
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
              )}
              {item.icon === 'pin' && (
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              )}
              {item.icon === 'route' && (
                <path d="M20.56 3.91c.39.39.39 1.02 0 1.41l-4.83 4.83-2.37-2.37 1.42-1.42c.39-.39 1.02-.39 1.41 0l.71.71 3.25-3.16c.39-.39 1.02-.39 1.41 0zM4 17.5V21h3.5l10.31-10.32-3.5-3.5L4 17.5zm-1.54 1.67a.996.996 0 000 1.41l1.47 1.47c.39.39 1.02.39 1.41 0l1.15-1.15-3.88-3.88-1.15 1.15z"/>
              )}
              {item.icon === 'send' && (
                <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
              )}
              {item.icon === 'chart' && (
                <path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"/>
              )}
            </svg>
          </div>

          <span class="mr-nav-label">{item.label}</span>
        </a>
      );
    })}
  </div>
</nav>

<style>
  .mr-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 40;
    background: rgba(6, 10, 14, 0.94);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid var(--border-light);
    padding-bottom: env(safe-area-inset-bottom);
  }

  :global(:not(.dark)) .mr-nav {
    background: rgba(255, 255, 255, 0.94);
  }

  .mr-nav-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    height: var(--bottom-nav-h);
    max-width: 28rem;
    margin: 0 auto;
  }

  .mr-nav-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    text-decoration: none;
    color: var(--text-tertiary);
    transition: color var(--transition-fast);
    -webkit-tap-highlight-color: transparent;

    &.active {
      color: var(--color-primary);
    }

    &:hover:not(.active) {
      color: var(--text-secondary);
    }

    &:active {
      transform: scale(0.93);
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: -3px;
      border-radius: 0.5rem;
    }
  }

  /* Green pill indicator at top of active item */
  .mr-nav-pill {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2rem;
    height: 3px;
    background: var(--color-primary);
    border-bottom-left-radius: 3px;
    border-bottom-right-radius: 3px;
    box-shadow: 0 0 8px rgba(0, 232, 162, 0.5);
  }

  /* Icon pill on active */
  .mr-nav-icon-wrap {
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.625rem;
    transition: background var(--transition-fast), transform var(--transition-fast);

    &.active {
      background: rgba(0, 232, 162, 0.12);
      transform: scale(1.08);
    }
  }

  .mr-nav-item:active .mr-nav-icon-wrap {
    transform: scale(0.9);
  }

  .mr-nav-label {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-align: center;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 4rem;
  }
</style>
