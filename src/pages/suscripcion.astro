---
import MainLayout from '../layouts/MainLayout.astro';
const proPriceMxn        = import.meta.env.PUBLIC_PRO_PRICE_MXN ?? '99';
const freeLimit          = import.meta.env.PUBLIC_PLAN_FREE_LIMIT ?? '5';

const stripePubKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY;
if (!stripePubKey) {
  throw new Error('Stripe publishable key is not configured. Please set PUBLIC_STRIPE_PUBLISHABLE_KEY.');
}

const stripeBuyButtonId = import.meta.env.PUBLIC_STRIPE_BUY_BUTTON_ID;
if (!stripeBuyButtonId) {
  throw new Error('Stripe Buy Button ID is not configured. Please set PUBLIC_STRIPE_BUY_BUTTON_ID.');
}
---

<MainLayout title="Mi suscripción">
  <!-- Script Stripe en <head> para que el custom element se defina antes de renderizar -->
  <Fragment slot="head">
    <script async src="https://js.stripe.com/v3/buy-button.js"></script>
  </Fragment>
  <div class="subs-page px-4 pt-4">

    <div class="page-header stagger-item">
      <h1 class="page-title">Mi plan</h1>
      <p class="page-sub">Gestiona tu suscripción</p>
    </div>

    <!-- Current plan card -->
    <div id="plan-card" class="plan-card stagger-item">
      <div class="plan-badge-row">
        <span id="plan-badge" class="plan-badge plan-free">Plan Gratuito</span>
        <span id="plan-status" class="plan-status"></span>
      </div>
      <div id="plan-details" class="plan-details"></div>
    </div>

    <!-- Pro card -->
    <div id="pro-card" class="pro-card stagger-item">
      <div class="pro-header">
        <div>
          <h2 class="pro-title">Mueve Reparto Pro</h2>
          <p class="pro-price">${proPriceMxn} MXN <span class="pro-period">/ mes</span></p>
        </div>
        <div class="pro-icon" aria-hidden="true">🚀</div>
      </div>

      <ul class="pro-features">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Paradas ilimitadas por día
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Historial de métricas completo (90 días)
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Registro de gasolina y rendimiento
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Modo conducción pantalla simplificada
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Notificaciones push de ruta y proximidad
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          Soporte prioritario por WhatsApp
        </li>
      </ul>

      <!-- Stripe Buy Button (visible solo si plan free) -->
      <div id="pro-cta" class="pro-cta">
        <div id="stripe-btn-wrapper">
          <stripe-buy-button
            buy-button-id={stripeBuyButtonId}
            publishable-key={stripePubKey}
          ></stripe-buy-button>
        </div>
        <p class="pay-note">Pago seguro con Stripe · Cancela cuando quieras</p>
      </div>
    </div>

    <!-- Free tier limits info -->
    <div id="free-info" class="info-card stagger-item">
      <p class="info-title">Plan Gratuito incluye:</p>
      <ul class="info-list">
        <li>Hasta <strong>{freeLimit} paradas activas</strong> por día</li>
        <li>Historial de 7 días en métricas</li>
        <li>Mapa con ruta optimizada</li>
        <li>Escáner QR + OCR de pedidos</li>
        <li>Notificaciones WhatsApp/Telegram</li>
        <li>100% offline — sin internet</li>
      </ul>
    </div>

    <!-- Account section -->
    <div id="account-section" class="account-card stagger-item" style="display:none;">
      <p class="account-label">Cuenta</p>
      <p id="account-phone" class="account-phone"></p>
      <button id="btn-logout" class="btn-danger btn-md" style="width:100%;margin-top:0.75rem;">
        Cerrar sesión
      </button>
    </div>

  </div>
</MainLayout>

<script>
  import { getSession, clearSession, isPro as checkPro } from '../lib/session';

  function renderPlan() {
    const session  = getSession();
    const email    = session?.email ?? '';
    const userId   = session?.userId ?? null;
    const isPro    = checkPro();

    const badge          = document.getElementById('plan-badge')!;
    const details        = document.getElementById('plan-details')!;
    const freeInfo       = document.getElementById('free-info')!;
    const stripeBtnWrap  = document.getElementById('stripe-btn-wrapper')!;
    const proCta         = document.getElementById('pro-cta')!;
    const accountSection = document.getElementById('account-section')!;
    const accountPhone   = document.getElementById('account-phone')!;

    if (isPro) {
      badge.textContent = 'Plan Pro ✦';
      badge.className   = 'plan-badge plan-pro';
      details.innerHTML = '<p style="font-size:0.875rem;color:var(--text-secondary);margin:0.5rem 0 0;">Paradas ilimitadas · Historial 90 días</p>';
      // Ocultar botón Stripe y mostrar mensaje pro
      stripeBtnWrap.style.display = 'none';
      proCta.innerHTML = `<p style="font-size:0.875rem;font-weight:700;color:var(--color-primary);text-align:center;padding:0.75rem 0 0;">
        ✅ Ya tienes el plan Pro activo
      </p>`;
      freeInfo.style.display = 'none';
    } else {
      badge.textContent = 'Plan Gratuito';
      badge.className   = 'plan-badge plan-free';
      details.innerHTML = `<p style="font-size:0.875rem;color:var(--text-secondary);margin:0.5rem 0 0;">Hasta 20 paradas activas por día</p>`;
      // El script de Stripe ya se cargó en <head> vía slot — no hacer nada aquí
    }

    // Sección cuenta
    accountSection.style.display = 'block';
    if (userId) {
      accountPhone.textContent = email || 'Cuenta activa';
      document.getElementById('btn-logout')?.addEventListener('click', () => {
        if (!confirm('¿Cerrar sesión?')) return;
        clearSession();
        window.location.href = '/auth';
      });
    } else {
      accountPhone.textContent = 'Sin cuenta — datos guardados en este dispositivo';
      const btnLogout = document.getElementById('btn-logout')!;
      btnLogout.textContent = 'Iniciar sesión';
      btnLogout.classList.remove('btn-danger');
      btnLogout.classList.add('btn-primary');
      btnLogout.addEventListener('click', () => { window.location.href = '/auth'; });
    }
  }

  document.addEventListener('astro:page-load', renderPlan);
  if (document.readyState !== 'loading') renderPlan();
</script>

<style>
  .subs-page {
    max-width: 480px;
    margin: 0 auto;
    padding-bottom: 2rem;
  }

  .page-header {
    margin-bottom: 1.25rem;
  }

  .page-title {
    font-size: 1.375rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 0.125rem;
  }

  .page-sub {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    font-weight: 600;
    margin: 0;
  }

  .plan-card {
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: 1.125rem;
    margin-bottom: 0.75rem;
  }

  .plan-badge-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .plan-badge {
    font-size: 0.8125rem;
    font-weight: 800;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .plan-free {
    background: var(--surface-elevated);
    color: var(--text-secondary);
    border: 1px solid var(--border-light);
  }

  .plan-pro {
    background: var(--color-primary-light);
    color: var(--text-brand);
    border: 1px solid var(--color-primary);
  }

  .plan-status {
    font-size: 0.75rem;
    color: var(--text-tertiary);
  }

  /* Pro upgrade card */
  .pro-card {
    background: linear-gradient(135deg, rgba(0,232,162,0.06) 0%, var(--surface-card) 100%);
    border: 1px solid rgba(0,232,162,0.25);
    border-radius: var(--radius-xl);
    padding: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .pro-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .pro-title {
    font-size: 1rem;
    font-weight: 900;
    color: var(--text-primary);
    margin: 0 0 0.25rem;
  }

  .pro-price {
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--color-primary);
    margin: 0;
  }

  .pro-period {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  .pro-icon {
    font-size: 2rem;
  }

  .pro-features {
    list-style: none;
    padding: 0;
    margin: 0 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pro-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 600;
  }

  /* Free info */
  .info-card {
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: 1.125rem;
    margin-bottom: 0.75rem;
  }

  .info-title {
    font-size: 0.875rem;
    font-weight: 800;
    color: var(--text-secondary);
    margin: 0 0 0.75rem;
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .info-list li {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    padding-left: 1rem;
    position: relative;
  }

  .info-list li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--text-tertiary);
  }

  /* Account */
  .account-card {
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: 1.125rem;
  }

  .account-label {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.25rem;
  }

  .account-phone {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .pay-note {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    text-align: center;
    margin: 0.5rem 0 0;
  }

  /* Forzar que el stripe-buy-button ocupe ancho completo */
  stripe-buy-button {
    width: 100%;
  }
</style>
