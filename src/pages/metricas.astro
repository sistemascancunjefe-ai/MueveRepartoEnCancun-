---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Métricas">
  <div class="metricas-page px-4 pt-4">

    <div class="stagger-item metricas-header">
      <h1 class="page-title">Métricas</h1>
      <p class="page-sub" id="week-label">Esta semana</p>
    </div>

    <!-- ── Weekly bar chart ── -->
    <div class="stagger-item chart-section glass-card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
        <p style="font-size:0.875rem;font-weight:800;color:var(--text-primary);margin:0;">Entregas por día</p>
        <span id="week-total-badge" class="badge badge-primary">— esta semana</span>
      </div>
      <div class="bar-chart" id="week-chart" aria-label="Gráfica de entregas por día">
        <!-- Filled by JS -->
        <div class="bar-col">
          <div class="bar-fill" style="height:0%"></div>
          <span class="bar-label">L</span>
        </div>
        <div class="bar-col">
          <div class="bar-fill" style="height:0%"></div>
          <span class="bar-label">M</span>
        </div>
        <div class="bar-col">
          <div class="bar-fill" style="height:0%"></div>
          <span class="bar-label">M</span>
        </div>
        <div class="bar-col">
          <div class="bar-fill" style="height:0%"></div>
          <span class="bar-label">J</span>
        </div>
        <div class="bar-col">
          <div class="bar-fill" style="height:0%"></div>
          <span class="bar-label">V</span>
        </div>
        <div class="bar-col">
          <div class="bar-fill" style="height:0%"></div>
          <span class="bar-label">S</span>
        </div>
        <div class="bar-col">
          <div class="bar-fill" style="height:0%"></div>
          <span class="bar-label">D</span>
        </div>
      </div>
      <div style="display:flex;justify-content:space-between;margin-top:0.75rem;">
        <span style="font-size:0.6875rem;color:var(--text-tertiary);">Lun</span>
        <span style="font-size:0.6875rem;color:var(--text-tertiary);">Dom</span>
      </div>
    </div>

    <!-- ── Today summary ── -->
    <div class="stagger-item">
      <p class="section-label">Hoy</p>
      <div class="metrics-grid">
        <div class="summary-card">
          <div class="summary-icon" style="background:rgba(0,232,162,0.1);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          </div>
          <span class="summary-value" id="today-done">0</span>
          <span class="summary-label">Entregadas</span>
        </div>
        <div class="summary-card">
          <div class="summary-icon" style="background:rgba(255,90,95,0.1);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-accent)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
          </div>
          <span class="summary-value" id="today-pending">0</span>
          <span class="summary-label">Pendientes</span>
        </div>
        <div class="summary-card">
          <div class="summary-icon" style="background:rgba(59,130,246,0.1);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#3B82F6"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
          </div>
          <span class="summary-value" id="today-income">$0</span>
          <span class="summary-label">Ingreso hoy</span>
        </div>
        <div class="summary-card">
          <div class="summary-icon" style="background:rgba(245,158,11,0.1);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#F59E0B"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"/></svg>
          </div>
          <span class="summary-value" id="today-time">—</span>
          <span class="summary-label">Tiempo activo</span>
        </div>
      </div>
    </div>

    <!-- ── ROI ── -->
    <div class="stagger-item">
      <p class="section-label">ROI semanal</p>
      <div class="roi-card glass-card">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.875rem;">
          <div>
            <p style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-tertiary);margin:0 0 0.25rem;">Ingreso esta semana</p>
            <span class="text-gradient-primary" style="font-size:2rem;font-weight:900;letter-spacing:-0.03em;" id="roi-income">$0</span>
          </div>
          <div style="text-align:right;">
            <p style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:var(--text-tertiary);margin:0 0 0.25rem;">vs semana ant.</p>
            <span id="roi-change" style="font-size:1.25rem;font-weight:900;color:var(--color-primary);">+0%</span>
          </div>
        </div>

        <!-- Weekly goal progress -->
        <div>
          <div style="display:flex;justify-content:space-between;margin-bottom:0.375rem;">
            <span style="font-size:0.75rem;font-weight:700;color:var(--text-secondary);">Meta semanal</span>
            <span style="font-size:0.75rem;font-weight:800;color:var(--text-primary);">
              <span id="goal-current">$0</span> / <span id="goal-target">$2,000</span>
            </span>
          </div>
          <div class="goal-track">
            <div class="goal-fill" id="goal-fill" style="width:0%;"></div>
          </div>
          <p style="font-size:0.6875rem;color:var(--text-tertiary);margin:0.375rem 0 0;text-align:right;" id="goal-pct">0% de la meta</p>
        </div>
      </div>
    </div>

    <!-- ── Top stats ── -->
    <div class="stagger-item">
      <p class="section-label">Mejor día</p>
      <div style="display:flex;gap:0.5rem;">
        <div class="stat-pill">
          <span style="font-size:0.6875rem;color:var(--text-tertiary);font-weight:600;">Más entregas</span>
          <span class="stat-pill-value" id="best-day-deliveries">—</span>
        </div>
        <div class="stat-pill">
          <span style="font-size:0.6875rem;color:var(--text-tertiary);font-weight:600;">Mayor ingreso</span>
          <span class="stat-pill-value" style="color:var(--color-primary);" id="best-day-income">$—</span>
        </div>
      </div>
    </div>

    <!-- ── Export ── -->
    <div class="stagger-item" style="padding-bottom:2rem;">
      <button id="btn-export-wa" class="btn-whatsapp btn-lg" style="width:100%;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Exportar resumen por WhatsApp
      </button>
    </div>

    <!-- Meta editor sheet -->
    <div id="goal-overlay" class="bottom-sheet-overlay" aria-hidden="true"></div>
    <div id="goal-sheet" class="bottom-sheet" role="dialog" aria-label="Configurar meta">
      <div class="sheet-handle"></div>
      <h2 style="font-size:1.125rem;font-weight:800;color:var(--text-primary);margin:0 0 0.375rem;">Meta semanal</h2>
      <p style="font-size:0.8125rem;color:var(--text-secondary);margin:0 0 1rem;">Ingreso objetivo para esta semana (MXN)</p>
      <input id="goal-input" type="number" min="100" step="100" class="input" placeholder="2000" />
      <button id="goal-save" class="btn-primary btn-lg" style="width:100%;margin-top:0.75rem;">Guardar meta</button>
    </div>

  </div>
</MainLayout>

<script>
  import { getStops, dbGetAll, STORES } from '../lib/idb';
  import type { Stop, DailyStats } from '../lib/idb';
  import { getRepartidorName } from '../lib/session';

  const WEEK_GOAL_KEY  = 'mr-week-goal';
  const WEEK_GOAL_DEFAULT = 2000;

  function getWeekDays(): Date[] {
    const today = new Date();
    const dow = today.getDay(); // 0=Sun
    const monday = new Date(today);
    monday.setDate(today.getDate() - ((dow + 6) % 7));
    return Array.from({ length: 7 }, (_, i) => {
      const d = new Date(monday);
      d.setDate(monday.getDate() + i);
      return d;
    });
  }

  function dateKey(d: Date): string {
    return d.toISOString().slice(0, 10);
  }

  function isSameDay(d: Date, ts: number): boolean {
    const t = new Date(ts);
    return t.getFullYear() === d.getFullYear() &&
           t.getMonth() === d.getMonth() &&
           t.getDate() === d.getDate();
  }

  async function loadMetrics() {
    const stops = await getStops();
    const today = new Date();
    const weekDays = getWeekDays();

    // Week label
    const weekLabel = document.getElementById('week-label');
    if (weekLabel) {
      const start = weekDays[0].toLocaleDateString('es-MX', { day: 'numeric', month: 'short' });
      const end   = weekDays[6].toLocaleDateString('es-MX', { day: 'numeric', month: 'short' });
      weekLabel.textContent = `${start} – ${end}`;
    }

    // Per-day counts for this week
    const dayCounts = weekDays.map(day => ({
      day,
      count:  stops.filter(s => s.status === 'completed' && s.completedAt && isSameDay(day, s.completedAt)).length,
      income: stops.filter(s => s.status === 'completed' && s.completedAt && isSameDay(day, s.completedAt))
                   .reduce((sum, s) => sum + (s.income ?? 0), 0),
    }));

    // Bar chart
    const maxCount = Math.max(...dayCounts.map(d => d.count), 1);
    const todayIdx = (today.getDay() + 6) % 7; // 0=Mon
    const bars = document.querySelectorAll('#week-chart .bar-fill');
    bars.forEach((bar, i) => {
      const pct = (dayCounts[i].count / maxCount) * 100;
      (bar as HTMLElement).style.height = `${Math.max(pct, 4)}%`;
      if (i === todayIdx) bar.classList.add('today');
    });

    // Week total badge
    const weekTotal = dayCounts.reduce((s, d) => s + d.count, 0);
    const badge = document.getElementById('week-total-badge');
    if (badge) badge.textContent = `${weekTotal} esta semana`;

    // Today summary
    const todayStats = dayCounts[todayIdx];
    const todayPending = stops.filter(s => s.status !== 'completed').length;
    document.getElementById('today-done')!.textContent    = String(todayStats.count);
    document.getElementById('today-pending')!.textContent = String(todayPending);
    document.getElementById('today-income')!.textContent  = `$${todayStats.income.toFixed(0)}`;

    // Week income for ROI
    const weekIncome = dayCounts.reduce((s, d) => s + d.income, 0);
    document.getElementById('roi-income')!.textContent = `$${weekIncome.toFixed(0)}`;

    // Goal
    const goal = parseInt(localStorage.getItem(WEEK_GOAL_KEY) ?? String(WEEK_GOAL_DEFAULT));
    const goalPct = Math.min((weekIncome / goal) * 100, 100);
    document.getElementById('goal-current')!.textContent = `$${weekIncome.toFixed(0)}`;
    document.getElementById('goal-target')!.textContent  = `$${goal.toLocaleString()}`;
    document.getElementById('goal-fill')!.style.width    = `${goalPct.toFixed(1)}%`;
    document.getElementById('goal-pct')!.textContent     = `${goalPct.toFixed(0)}% de la meta`;

    // Best days
    const bestCount = Math.max(...dayCounts.map(d => d.count));
    const bestIncome = Math.max(...dayCounts.map(d => d.income));
    const bestCountDay  = dayCounts.find(d => d.count === bestCount);
    const bestIncomeDay = dayCounts.find(d => d.income === bestIncome);
    const dayNames = ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'];
    document.getElementById('best-day-deliveries')!.textContent =
      bestCount > 0
        ? `${bestCount} (${dayNames[dayCounts.indexOf(bestCountDay!)]})`
        : '—';
    document.getElementById('best-day-income')!.textContent =
      bestIncome > 0
        ? `$${bestIncome} (${dayNames[dayCounts.indexOf(bestIncomeDay!)]})`
        : '$—';

    // ROI change (compare to prev week placeholder)
    // TODO: implement with STORES.STATS once backend is live
    document.getElementById('roi-change')!.textContent = weekIncome > 0 ? '+—%' : '—';
  }

  function buildExportMessage(): string {
    const todayDone    = document.getElementById('today-done')?.textContent ?? '0';
    const todayIncome  = document.getElementById('today-income')?.textContent ?? '$0';
    const weekTotal    = document.getElementById('week-total-badge')?.textContent?.split(' ')[0] ?? '0';
    const weekIncome   = document.getElementById('roi-income')?.textContent ?? '$0';
    const repartidor   = getRepartidorName() || 'Repartidor';
    const today        = new Date().toLocaleDateString('es-MX', { weekday: 'long', day: 'numeric', month: 'long' });

    return `*Mueve Reparto — Resumen ${today}*\n\n` +
      `👤 ${repartidor}\n\n` +
      `*Hoy:*\n` +
      `✅ Entregas: ${todayDone}\n` +
      `💰 Ingreso: ${todayIncome}\n\n` +
      `*Esta semana:*\n` +
      `📦 Total entregas: ${weekTotal}\n` +
      `💵 Ingreso semanal: ${weekIncome}\n\n` +
      `_Enviado desde Mueve Reparto_`;
  }

  function initGoalEditor() {
    const goalCard = document.querySelector('.roi-card');
    const overlay  = document.getElementById('goal-overlay')!;
    const sheet    = document.getElementById('goal-sheet')!;
    const input    = document.getElementById('goal-input') as HTMLInputElement;
    const save     = document.getElementById('goal-save')!;

    goalCard?.addEventListener('click', () => {
      input.value = localStorage.getItem(WEEK_GOAL_KEY) ?? String(WEEK_GOAL_DEFAULT);
      overlay.classList.add('open');
      sheet.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
    });

    overlay.addEventListener('click', () => {
      overlay.classList.remove('open');
      sheet.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
    });

    save.addEventListener('click', async () => {
      const val = parseInt(input.value);
      if (val > 0) {
        localStorage.setItem(WEEK_GOAL_KEY, String(val));
        overlay.classList.remove('open');
        sheet.classList.remove('open');
        overlay.setAttribute('aria-hidden', 'true');
        await loadMetrics();
      }
    });
  }

  async function init() {
    await loadMetrics();
    initGoalEditor();

    document.getElementById('btn-export-wa')?.addEventListener('click', () => {
      const msg = encodeURIComponent(buildExportMessage());
      window.open(`https://wa.me/?text=${msg}`, '_blank', 'noopener,noreferrer');
    });
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') init();
</script>

<style>
  .metricas-page { max-width: 480px; margin: 0 auto; }

  .metricas-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .page-title {
    font-size: 1.375rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 0.125rem;
  }

  .page-sub {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    font-weight: 500;
    margin: 0;
  }

  .section-label {
    font-size: 0.625rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.625rem;
    margin-top: 1.25rem;
  }

  .section-label::after {
    content: '';
    height: 1px;
    flex: 1;
    background: var(--border-light);
  }

  .chart-section {
    margin-bottom: 0.25rem;
  }

  .bar-chart {
    display: flex;
    align-items: flex-end;
    gap: 0.375rem;
    height: 90px;
  }

  .bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    height: 100%;
    justify-content: flex-end;
  }

  .bar-fill {
    width: 100%;
    border-radius: 4px 4px 0 0;
    background: rgba(0, 232, 162, 0.2);
    transition: height 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    min-height: 4px;
  }

  .bar-fill.today {
    background: var(--color-primary);
    box-shadow: 0 0 8px rgba(0, 232, 162, 0.3);
  }

  .bar-label {
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--text-tertiary);
    letter-spacing: 0.04em;
  }

  /* Summary cards */
  .metrics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .summary-card {
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .summary-icon {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.125rem;
  }

  .summary-value {
    font-size: 1.375rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1;
  }

  .summary-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
  }

  /* ROI card */
  .roi-card {
    cursor: pointer;
  }

  .roi-card:hover {
    border-color: var(--color-primary);
  }

  /* Goal progress */
  .goal-track {
    width: 100%;
    height: 8px;
    background: var(--border-light);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .goal-fill {
    height: 100%;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    transition: width 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 0 6px rgba(0, 232, 162, 0.3);
  }

  /* Stat pills */
  .stat-pill {
    flex: 1;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .stat-pill-value {
    font-size: 1rem;
    font-weight: 900;
    color: var(--text-primary);
  }
</style>
