---
import MainLayout from '../layouts/MainLayout.astro';

const title = "Metricas";
---

<MainLayout title={title}>
  <div class="page">

    <div class="page-header">
      <div>
        <h1 class="page-title">Metricas</h1>
        <p class="page-sub">Ultimos 7 dias de actividad</p>
      </div>
      <span class="badge badge-teal">Esta semana</span>
    </div>

    <!-- Weekly metrics -->
    <div class="metrics">
      <div class="metric">
        <div class="metric-val t" id="wm-total">0</div>
        <div class="metric-lbl">Pedidos sem.</div>
      </div>
      <div class="metric">
        <div class="metric-val" id="wm-avg">0</div>
        <div class="metric-lbl">Promedio/dia</div>
      </div>
      <div class="metric">
        <div class="metric-val a" id="wm-income">$0</div>
        <div class="metric-lbl">Ingreso sem.</div>
      </div>
      <div class="metric">
        <div class="metric-val g" id="wm-roi">$0</div>
        <div class="metric-lbl">ROI vs sin app</div>
      </div>
    </div>

    <!-- Chart -->
    <div class="card">
      <div class="chart-header">
        <span class="section-label">PEDIDOS POR DIA</span>
        <span class="chart-range">Lun &ndash; Dom</span>
      </div>
      <div class="week-chart" id="week-chart"></div>
      <div class="week-days" id="week-days"></div>
    </div>

    <!-- ROI breakdown -->
    <div class="card">
      <p class="section-label" style="margin-bottom:.8rem">ROI MATEMATICO &mdash; $70/semana vs. ingreso extra</p>
      <div class="roi-grid">
        <div class="roi-item">
          <div class="roi-label">COSTO SUSCRIPCION</div>
          <div class="roi-val">$70 <span class="roi-unit">/semana</span></div>
        </div>
        <div class="roi-item">
          <div class="roi-label">BREAK-EVEN</div>
          <div class="roi-val t">1 <span class="roi-unit">pedido extra/dia</span></div>
        </div>
        <div class="roi-item">
          <div class="roi-label">ESCENARIO +15%</div>
          <div class="roi-val t" id="roi-15">$0 <span class="roi-unit">extra/sem</span></div>
        </div>
        <div class="roi-item">
          <div class="roi-label">ROI ESTIMADO</div>
          <div class="roi-val a" id="roi-pct">0%</div>
        </div>
      </div>
    </div>

    <!-- Today summary -->
    <div class="card">
      <p class="section-label" style="margin-bottom:.75rem">RESUMEN DE HOY</p>
      <div id="today-stops" class="today-list"></div>
    </div>

    <!-- Goals -->
    <div class="card">
      <p class="section-label" style="margin-bottom:.65rem">META SEMANAL</p>
      <div class="goal-row">
        <div class="goal-info">
          <p class="goal-target">Meta: <span id="goal-target">0</span> pedidos</p>
          <p class="goal-actual">Actual: <span id="goal-actual">0</span> pedidos</p>
        </div>
        <div class="goal-input-row">
          <input class="inp" id="inp-goal" type="number" min="1" max="999" placeholder="100" />
          <button class="btn btn-primary btn-sm" id="btn-set-goal">Guardar</button>
        </div>
      </div>
      <div class="goal-bar">
        <div class="goal-fill" id="goal-fill" style="width:0%"></div>
      </div>
      <p class="goal-pct" id="goal-pct">0% de la meta</p>
    </div>

  </div>
</MainLayout>

<script>
const STORE_KEY = 'mr_stops';
const GOAL_KEY  = 'mr_weekly_goal';

function getStops(): any[] {
  try { return JSON.parse(sessionStorage.getItem(STORE_KEY) || '[]'); } catch { return []; }
}

// Demo weekly data (replace with real storage in production)
const DEMO_WEEK = [14, 18, 22, 16, 25, 31, 0];
const DAYS = ['L','M','X','J','V','S','D'];

function render() {
  const stops = getStops();
  const delivered = stops.filter((s: any) => s.status === 'delivered').length;

  // Weekly totals (demo + today)
  const todayDelivered = delivered;
  const weekData = [...DEMO_WEEK.slice(0, 6), todayDelivered];
  const total  = weekData.reduce((a, b) => a + b, 0);
  const avg    = Math.round(total / 7);
  const income = total * 13;
  const extra15 = Math.round(total * 0.15) * 13;
  const roi    = Math.round((extra15 - 70) / 70 * 100);

  (document.getElementById('wm-total') as HTMLElement).textContent  = String(total);
  (document.getElementById('wm-avg') as HTMLElement).textContent    = String(avg);
  (document.getElementById('wm-income') as HTMLElement).textContent = `$${income}`;
  (document.getElementById('wm-roi') as HTMLElement).textContent    = `$${Math.max(0, extra15 - 70)}`;
  (document.getElementById('roi-15') as HTMLElement).innerHTML      = `$${Math.max(0, extra15 - 70)} <span class="roi-unit">extra/sem</span>`;
  (document.getElementById('roi-pct') as HTMLElement).textContent   = roi + '%';

  // Bar chart
  const max = Math.max(...weekData, 1);
  const chartEl = document.getElementById('week-chart') as HTMLElement;
  chartEl.innerHTML = weekData.map((v, i) => `
    <div class="bar-wrap" title="${v} pedidos">
      <div class="bar-fill" style="height:${v > 0 ? Math.max(v / max * 100, 5) : 2}%"></div>
    </div>
  `).join('');

  const daysEl = document.getElementById('week-days') as HTMLElement;
  daysEl.innerHTML = DAYS.map((d, i) => `<span class="${i === 6 ? 'day-today' : ''}">${d}</span>`).join('');

  // Today summary
  const todayEl = document.getElementById('today-stops') as HTMLElement;
  if (stops.length === 0) {
    todayEl.innerHTML = `<p class="today-empty">Sin paradas registradas hoy</p>`;
  } else {
    const summary = [
      { label: 'Total', val: stops.length, color: 'var(--text-primary)' },
      { label: 'Entregados', val: stops.filter((s: any) => s.status === 'delivered').length, color: '#16a34a' },
      { label: 'Pendientes', val: stops.filter((s: any) => s.status === 'pending').length, color: 'var(--text-secondary)' },
      { label: 'En ruta', val: stops.filter((s: any) => s.status === 'in_route').length, color: '#0d9488' },
      { label: 'Fallidos', val: stops.filter((s: any) => s.status === 'failed').length, color: '#ef4444' },
    ];
    todayEl.innerHTML = summary.map(item => `
      <div class="today-row">
        <span class="today-label">${item.label}</span>
        <span class="today-val" style="color:${item.color}">${item.val}</span>
      </div>
    `).join('');
  }

  // Goals
  const goal = +(localStorage.getItem(GOAL_KEY) || '0');
  const goalTarget = document.getElementById('goal-target') as HTMLElement;
  const goalActual = document.getElementById('goal-actual') as HTMLElement;
  const goalFill   = document.getElementById('goal-fill') as HTMLElement;
  const goalPct    = document.getElementById('goal-pct') as HTMLElement;
  goalTarget.textContent = String(goal || '—');
  goalActual.textContent = String(total);
  const pct = goal > 0 ? Math.min(Math.round(total / goal * 100), 100) : 0;
  goalFill.style.width = pct + '%';
  goalPct.textContent  = goal > 0 ? `${pct}% de la meta` : 'Establece una meta semanal';
}

function init() {
  render();

  document.getElementById('btn-set-goal')?.addEventListener('click', () => {
    const val = +(document.getElementById('inp-goal') as HTMLInputElement).value;
    if (val > 0) {
      localStorage.setItem(GOAL_KEY, String(val));
      render();
      window.showToast?.(`Meta: ${val} pedidos/semana`, 'success');
    }
  });
}

document.addEventListener('astro:page-load', init);
</script>

<style>
.page {
  display: flex; flex-direction: column; gap: 1rem;
  padding: 1rem; max-width: 480px; margin: 0 auto;
}

.page-header { display: flex; align-items: flex-start; justify-content: space-between; }
.page-title { font-size: 1.15rem; font-weight: 800; color: var(--text-primary); margin: 0; }
.page-sub { font-size: .78rem; color: var(--text-tertiary); margin: .15rem 0 0; }

/* Metrics */
.metrics { display: grid; grid-template-columns: repeat(2,1fr); gap: .6rem; }
.metric { background: var(--surface-card); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: .9rem; }
.metric-val { font-family: monospace; font-size: 1.75rem; font-weight: 700; line-height: 1; margin-bottom: .2rem; color: var(--text-primary); }
.metric-val.t { color: var(--color-teal); }
.metric-val.a { color: #f97316; }
.metric-val.g { color: #16a34a; }
.metric-lbl { font-size: .68rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--text-tertiary); }

/* Card */
.card { background: var(--surface-card); border: 1px solid var(--border-light); border-radius: var(--radius-lg); padding: 1rem 1.1rem; }

/* Chart */
.chart-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: .75rem; }
.section-label { font-size: .68rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--text-tertiary); }
.chart-range { font-family: monospace; font-size: .65rem; color: var(--text-tertiary); }

.week-chart { display: flex; align-items: flex-end; gap: .25rem; height: 60px; margin-bottom: .4rem; }
.bar-wrap { flex: 1; display: flex; align-items: flex-end; height: 100%; }
.bar-fill {
  width: 100%; border-radius: 3px 3px 0 0; min-height: 2px;
  background: linear-gradient(0deg, var(--color-teal), rgba(13,148,136,.4));
  transition: height .5s cubic-bezier(.16,1,.3,1);
}

.week-days { display: flex; justify-content: space-around; }
.week-days span { font-family: monospace; font-size: .6rem; color: var(--text-tertiary); }
.day-today { color: var(--color-teal) !important; font-weight: 700; }

/* ROI grid */
.roi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
.roi-item { }
.roi-label { font-family: monospace; font-size: .62rem; letter-spacing: .06em; text-transform: uppercase; color: var(--text-tertiary); margin-bottom: .2rem; }
.roi-val { font-family: monospace; font-size: 1.15rem; font-weight: 700; color: var(--text-primary); }
.roi-val.t { color: var(--color-teal); }
.roi-val.a { color: #f97316; }
.roi-unit { font-size: .65rem; font-weight: 400; color: var(--text-tertiary); }

/* Today summary */
.today-list { display: flex; flex-direction: column; gap: .25rem; }
.today-row { display: flex; align-items: center; justify-content: space-between; padding: .3rem 0; border-bottom: 1px solid var(--border-subtle); }
.today-row:last-child { border-bottom: none; }
.today-label { font-size: .82rem; color: var(--text-secondary); }
.today-val { font-family: monospace; font-size: .88rem; font-weight: 700; }
.today-empty { font-size: .82rem; color: var(--text-tertiary); text-align: center; padding: .75rem; margin: 0; }

/* Goals */
.goal-row { display: flex; align-items: flex-start; justify-content: space-between; gap: .75rem; margin-bottom: .65rem; }
.goal-info { flex: 1; }
.goal-target, .goal-actual { font-size: .82rem; color: var(--text-secondary); margin: 0 0 .15rem; }
.goal-input-row { display: flex; gap: .35rem; flex-shrink: 0; }
.goal-bar { height: 6px; background: rgba(0,0,0,.07); border-radius: 99px; overflow: hidden; margin-bottom: .4rem; }
:global(.dark) .goal-bar { background: rgba(255,255,255,.08); }
.goal-fill { height: 100%; background: linear-gradient(90deg, var(--color-teal), #14b8a6); border-radius: 99px; transition: width .6s cubic-bezier(.16,1,.3,1); }
.goal-pct { font-family: monospace; font-size: .72rem; color: var(--text-tertiary); margin: 0; }

/* Inputs */
.inp { background: rgba(0,0,0,.04); border: 1.5px solid var(--border-light); border-radius: var(--radius-md); padding: .4rem .7rem; color: var(--text-primary); font-size: .9rem; width: 70px; outline: none; font-family: inherit; }
:global(.dark) .inp { background: rgba(255,255,255,.05); }
.inp:focus { border-color: var(--color-teal); }

/* Buttons */
.btn { display: inline-flex; align-items: center; justify-content: center; gap: .35rem; padding: .5rem 1rem; border-radius: var(--radius-md); border: none; cursor: pointer; font-size: .88rem; font-weight: 700; text-decoration: none; transition: all .15s; }
.btn:active { transform: scale(.96); }
.btn-primary { background: var(--gradient-primary); color: white; }
.btn-sm { padding: .35rem .75rem; font-size: .8rem; }

/* Badge */
.badge { display: inline-flex; align-items: center; padding: 2px 9px; border-radius: 99px; font-size: .62rem; font-weight: 700; border: 1px solid; }
.badge-teal { color: var(--color-teal); border-color: rgba(13,148,136,.3); background: rgba(13,148,136,.08); }
</style>
