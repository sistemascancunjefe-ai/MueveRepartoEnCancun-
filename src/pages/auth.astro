---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Iniciar sesión" hideNav={true}>
  <div class="auth-page">

    <!-- Logo / Brand -->
    <div class="auth-brand">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
              fill="var(--color-primary)" />
      </svg>
      <h1 class="brand-name">Mueve Reparto</h1>
      <p class="brand-tagline">Gestiona tus entregas del día</p>
    </div>

    <!-- Step 1: Email -->
    <div id="step-email" class="auth-card">
      <h2 class="step-title">Ingresa tu correo</h2>
      <p class="step-sub">Te enviaremos un enlace de acceso directo — sin contraseña</p>

      <input
        id="input-email"
        type="email"
        inputmode="email"
        autocomplete="email"
        placeholder="tu@correo.com"
        class="input"
        style="margin-bottom:1rem;font-size:1rem;"
      />

      <button id="btn-send" class="btn-primary btn-lg auth-btn" disabled>
        Enviar enlace
      </button>

      <p id="email-error" class="auth-error" style="display:none;"></p>

      <p class="auth-skip">
        <a href="/home" class="skip-link">Continuar sin cuenta (modo offline)</a>
      </p>
    </div>

    <!-- Step 2: Check your email -->
    <div id="step-sent" class="auth-card" style="display:none;">
      <div style="text-align:center;padding:0.5rem 0 1rem;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
      </div>
      <h2 class="step-title" style="text-align:center;">Revisa tu correo</h2>
      <p class="step-sub" style="text-align:center;">
        Enviamos un enlace a <strong id="sent-email" style="color:var(--text-primary)"></strong>.<br>
        Haz clic en el enlace para entrar — expira en 15 minutos.
      </p>

      <p style="font-size:0.8125rem;color:var(--text-tertiary);text-align:center;margin-top:0.5rem;">
        ¿No llegó? Revisa spam o
        <button id="btn-resend" class="inline-link">reenvía el enlace</button>
        <span id="resend-wait" style="display:none;">en <span id="resend-timer">60</span>s</span>
      </p>

      <button id="btn-back" class="btn-secondary btn-lg auth-btn" style="margin-top:1.25rem;">
        Usar otro correo
      </button>
    </div>

    <!-- Loading -->
    <div id="auth-loading" class="auth-loading" style="display:none;">
      <div class="spinner"></div>
      <p>Un momento...</p>
    </div>

  </div>
</MainLayout>

<script>
  import { isLoggedIn } from '../lib/session';

  const API_URL = import.meta.env.PUBLIC_API_URL ?? '';

  if (isLoggedIn()) window.location.href = '/home';

  const inputEmail   = document.getElementById('input-email') as HTMLInputElement;
  const btnSend      = document.getElementById('btn-send') as HTMLButtonElement;
  const emailError   = document.getElementById('email-error')!;
  const stepEmail    = document.getElementById('step-email')!;
  const stepSent     = document.getElementById('step-sent')!;
  const sentEmailEl  = document.getElementById('sent-email')!;
  const btnResend    = document.getElementById('btn-resend')!;
  const btnBack      = document.getElementById('btn-back')!;
  const resendWait   = document.getElementById('resend-wait')!;
  const resendTimer  = document.getElementById('resend-timer')!;
  const authLoading  = document.getElementById('auth-loading')!;

  let currentEmail = '';
  let resendInterval: ReturnType<typeof setInterval> | null = null;

  function isValidEmail(e: string) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e);
  }

  inputEmail.addEventListener('input', () => {
    btnSend.disabled = !isValidEmail(inputEmail.value.trim());
    emailError.style.display = 'none';
  });

  inputEmail.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !btnSend.disabled) btnSend.click();
  });

  async function sendLink(email: string) {
    setLoading(true);
    try {
      const res = await fetch(`${API_URL}/auth/magic-link`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.status === 429) {
        showError('Demasiados intentos. Espera una hora.');
        return;
      }
      if (!res.ok) {
        showError('No pudimos enviar el enlace. Intenta de nuevo.');
        return;
      }

      currentEmail = email;
      sentEmailEl.textContent = email;
      stepEmail.style.display = 'none';
      stepSent.style.display  = 'block';
      startResendCountdown();
    } catch {
      showError('Error de conexión. Verifica tu internet.');
    } finally {
      setLoading(false);
    }
  }

  btnSend.addEventListener('click', () => {
    const email = inputEmail.value.trim().toLowerCase();
    if (!isValidEmail(email)) return;
    sendLink(email);
  });

  btnResend.addEventListener('click', async () => {
    if (btnResend.getAttribute('disabled') !== null) return;
    btnResend.setAttribute('disabled', '');
    await sendLink(currentEmail);
  });

  btnBack.addEventListener('click', () => {
    stepSent.style.display  = 'none';
    stepEmail.style.display = 'block';
    if (resendInterval) clearInterval(resendInterval);
  });

  function startResendCountdown() {
    let secs = 60;
    resendTimer.textContent = String(secs);
    resendWait.style.display  = 'inline';
    btnResend.setAttribute('disabled', '');
    btnResend.style.opacity = '0.4';

    resendInterval = setInterval(() => {
      secs--;
      resendTimer.textContent = String(secs);
      if (secs <= 0) {
        clearInterval(resendInterval!);
        resendWait.style.display = 'none';
        btnResend.removeAttribute('disabled');
        btnResend.style.opacity = '1';
      }
    }, 1000);
  }

  function showError(msg: string) {
    emailError.textContent = msg;
    emailError.style.display = 'block';
  }

  function setLoading(show: boolean) {
    authLoading.style.display = show ? 'flex' : 'none';
    btnSend.disabled = show || !isValidEmail(inputEmail.value.trim());
  }
</script>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1.25rem;
    max-width: 400px;
    margin: 0 auto;
    gap: 2rem;
  }

  .auth-brand { text-align: center; }

  .brand-name {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0.5rem 0 0.25rem;
  }

  .brand-tagline {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin: 0;
  }

  .auth-card {
    width: 100%;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
  }

  .step-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0 0 0.375rem;
  }

  .step-sub {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .auth-btn { width: 100%; }

  .auth-error {
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .auth-skip {
    text-align: center;
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  .skip-link {
    color: var(--text-tertiary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .inline-link {
    background: none;
    border: none;
    color: var(--color-primary);
    font-size: inherit;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .inline-link[disabled] { opacity: 0.4; cursor: default; }

  .auth-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .spinner {
    width: 28px;
    height: 28px;
    border: 3px solid var(--border-light);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
</style>
