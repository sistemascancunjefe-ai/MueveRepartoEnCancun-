---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Iniciar sesión" hideNav={true}>
  <div class="auth-page">

    <!-- Logo / Brand -->
    <div class="auth-brand">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
              fill="var(--color-primary)" />
      </svg>
      <h1 class="brand-name">Mueve Reparto</h1>
      <p class="brand-tagline">Gestiona tus entregas del día</p>
    </div>

    <!-- Step 1: Phone -->
    <div id="step-phone" class="auth-card">
      <h2 class="step-title">Ingresa tu número</h2>
      <p class="step-sub">Te enviaremos un código de 6 dígitos por SMS</p>

      <div class="phone-input-wrap">
        <span class="phone-prefix">🇲🇽 +52</span>
        <input
          id="input-phone"
          type="tel"
          inputmode="numeric"
          maxlength="10"
          placeholder="1234567890"
          class="input phone-input"
          autocomplete="tel-national"
        />
      </div>

      <button id="btn-send-otp" class="btn-primary btn-lg auth-btn" disabled>
        Enviar código
      </button>

      <p id="phone-error" class="auth-error" style="display:none;"></p>

      <p class="auth-skip">
        <a href="/home" class="skip-link">Continuar sin cuenta (modo offline)</a>
      </p>
    </div>

    <!-- Step 2: OTP Code -->
    <div id="step-otp" class="auth-card" style="display:none;">
      <button id="btn-back" class="back-btn" aria-label="Volver">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/></svg>
      </button>
      <h2 class="step-title">Código de verificación</h2>
      <p id="otp-sub" class="step-sub">Código enviado a +52 <span id="otp-phone-display"></span></p>

      <div class="otp-inputs" role="group" aria-label="Código de 6 dígitos">
        <input class="otp-digit" type="tel" inputmode="numeric" maxlength="1" pattern="[0-9]" />
        <input class="otp-digit" type="tel" inputmode="numeric" maxlength="1" pattern="[0-9]" />
        <input class="otp-digit" type="tel" inputmode="numeric" maxlength="1" pattern="[0-9]" />
        <input class="otp-digit" type="tel" inputmode="numeric" maxlength="1" pattern="[0-9]" />
        <input class="otp-digit" type="tel" inputmode="numeric" maxlength="1" pattern="[0-9]" />
        <input class="otp-digit" type="tel" inputmode="numeric" maxlength="1" pattern="[0-9]" />
      </div>

      <button id="btn-verify-otp" class="btn-primary btn-lg auth-btn" disabled>
        Verificar
      </button>

      <p id="otp-error" class="auth-error" style="display:none;"></p>

      <button id="btn-resend" class="resend-btn" disabled>
        Reenviar código (<span id="resend-timer">60</span>s)
      </button>
    </div>

    <!-- Loading spinner -->
    <div id="auth-loading" class="auth-loading" style="display:none;">
      <div class="spinner"></div>
      <p>Un momento...</p>
    </div>

  </div>
</MainLayout>

<script>
  import { saveSession, isLoggedIn } from '../lib/session';

  const API_URL = import.meta.env.PUBLIC_API_URL ?? '';

  let currentPhone = '';
  let resendInterval: ReturnType<typeof setInterval> | null = null;

  // ── Phone step ──────────────────────────────────────────────────────────────

  function normalizePhone(raw: string): string {
    return raw.replace(/\D/g, '').slice(0, 10);
  }

  const phoneInput   = document.getElementById('input-phone') as HTMLInputElement;
  const btnSendOtp   = document.getElementById('btn-send-otp') as HTMLButtonElement;
  const phoneError   = document.getElementById('phone-error')!;
  const stepPhone    = document.getElementById('step-phone')!;
  const stepOtp      = document.getElementById('step-otp')!;
  const authLoading  = document.getElementById('auth-loading')!;

  phoneInput.addEventListener('input', () => {
    const digits = normalizePhone(phoneInput.value);
    phoneInput.value = digits;
    btnSendOtp.disabled = digits.length !== 10;
    phoneError.style.display = 'none';
  });

  btnSendOtp.addEventListener('click', async () => {
    const digits = normalizePhone(phoneInput.value);
    if (digits.length !== 10) return;

    currentPhone = digits;
    setLoading(true);

    try {
      const res = await fetch(`${API_URL}/auth/send-otp`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: digits }),
      });

      if (res.status === 429) {
        showPhoneError('Demasiados intentos. Espera una hora.');
        return;
      }
      if (!res.ok) {
        showPhoneError('No pudimos enviar el código. Intenta de nuevo.');
        return;
      }

      const data = await res.json();

      // Modo dev: código en la respuesta
      if (data.dev_code) {
        console.info(`[DEV] OTP code: ${data.dev_code}`);
        // Auto-fill in dev
        const digits = document.querySelectorAll<HTMLInputElement>('.otp-digit');
        data.dev_code.split('').forEach((d: string, i: number) => {
          if (digits[i]) digits[i].value = d;
        });
      }

      showOtpStep();
    } catch {
      showPhoneError('Error de conexión. Verifica tu internet.');
    } finally {
      setLoading(false);
    }
  });

  function showPhoneError(msg: string) {
    phoneError.textContent = msg;
    phoneError.style.display = 'block';
  }

  // ── OTP step ────────────────────────────────────────────────────────────────

  const otpPhoneDisplay = document.getElementById('otp-phone-display')!;
  const btnVerifyOtp    = document.getElementById('btn-verify-otp') as HTMLButtonElement;
  const btnBack         = document.getElementById('btn-back')!;
  const btnResend       = document.getElementById('btn-resend') as HTMLButtonElement;
  const resendTimer     = document.getElementById('resend-timer')!;
  const otpError        = document.getElementById('otp-error')!;
  const otpDigits       = document.querySelectorAll<HTMLInputElement>('.otp-digit');

  function showOtpStep() {
    stepPhone.style.display = 'none';
    stepOtp.style.display = 'block';
    otpPhoneDisplay.textContent = currentPhone;
    startResendTimer();
    otpDigits[0]?.focus();
  }

  btnBack.addEventListener('click', () => {
    stepOtp.style.display = 'none';
    stepPhone.style.display = 'block';
    clearOtpInputs();
    if (resendInterval) clearInterval(resendInterval);
  });

  // OTP digit navigation
  otpDigits.forEach((input, i) => {
    input.addEventListener('input', () => {
      input.value = input.value.replace(/\D/g, '').slice(-1);
      if (input.value && i < otpDigits.length - 1) {
        otpDigits[i + 1].focus();
      }
      updateVerifyBtn();
      otpError.style.display = 'none';
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Backspace' && !input.value && i > 0) {
        otpDigits[i - 1].focus();
      }
    });

    input.addEventListener('paste', (e) => {
      e.preventDefault();
      const pasted = e.clipboardData?.getData('text').replace(/\D/g, '') ?? '';
      pasted.split('').slice(0, 6).forEach((char, j) => {
        if (otpDigits[j]) otpDigits[j].value = char;
      });
      updateVerifyBtn();
      otpDigits[Math.min(pasted.length, 5)].focus();
    });
  });

  function getOtpCode(): string {
    return Array.from(otpDigits).map(d => d.value).join('');
  }

  function updateVerifyBtn() {
    btnVerifyOtp.disabled = getOtpCode().length !== 6;
  }

  function clearOtpInputs() {
    otpDigits.forEach(d => d.value = '');
    updateVerifyBtn();
  }

  btnVerifyOtp.addEventListener('click', verifyOtp);

  async function verifyOtp() {
    const code = getOtpCode();
    if (code.length !== 6) return;

    setLoading(true);

    try {
      const res = await fetch(`${API_URL}/auth/verify-otp`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: currentPhone, code }),
      });

      if (res.status === 401) {
        otpError.textContent = 'Código incorrecto o expirado. Intenta de nuevo.';
        otpError.style.display = 'block';
        clearOtpInputs();
        otpDigits[0]?.focus();
        return;
      }
      if (!res.ok) {
        otpError.textContent = 'Error al verificar. Intenta de nuevo.';
        otpError.style.display = 'block';
        return;
      }

      const data = await res.json();
      saveSession({
        token:  data.token,
        plan:   data.plan ?? 'free',
        userId: data.user_id ?? '',
        phone:  `+52${currentPhone}`,
      });

      // Redirigir al origen o /home
      const redirectTo = new URLSearchParams(window.location.search).get('next') ?? '/home';
      window.location.href = redirectTo;
    } catch {
      otpError.textContent = 'Error de conexión.';
      otpError.style.display = 'block';
    } finally {
      setLoading(false);
    }
  }

  // Resend timer
  function startResendTimer() {
    let seconds = 60;
    resendTimer.textContent = String(seconds);
    btnResend.disabled = true;

    resendInterval = setInterval(() => {
      seconds--;
      resendTimer.textContent = String(seconds);
      if (seconds <= 0) {
        clearInterval(resendInterval!);
        btnResend.disabled = false;
        btnResend.textContent = 'Reenviar código';
      }
    }, 1000);
  }

  btnResend.addEventListener('click', async () => {
    if (btnResend.disabled) return;
    btnResend.disabled = true;
    try {
      await fetch(`${API_URL}/auth/send-otp`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ phone: currentPhone }),
      });
      clearOtpInputs();
      startResendTimer();
    } catch {
      btnResend.disabled = false;
    }
  });

  // ── Helpers ─────────────────────────────────────────────────────────────────

  function setLoading(show: boolean) {
    authLoading.style.display = show ? 'flex' : 'none';
    btnSendOtp.disabled = show;
    btnVerifyOtp.disabled = show;
  }

  // Si ya tiene sesión, redirigir
  if (isLoggedIn()) window.location.href = '/home';
</script>

<style>
  .auth-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1.25rem;
    max-width: 400px;
    margin: 0 auto;
    gap: 2rem;
  }

  .auth-brand {
    text-align: center;
  }

  .brand-name {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0.5rem 0 0.25rem;
  }

  .brand-tagline {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin: 0;
  }

  .auth-card {
    width: 100%;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: 1.5rem;
    position: relative;
  }

  .step-title {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--text-primary);
    margin: 0 0 0.375rem;
  }

  .step-sub {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0 0 1.25rem;
  }

  .phone-input-wrap {
    display: flex;
    align-items: center;
    background: var(--surface-input);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .phone-prefix {
    padding: 0 0.75rem;
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-secondary);
    border-right: 1px solid var(--border-light);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .phone-input {
    border: none !important;
    border-radius: 0 !important;
    background: transparent !important;
    flex: 1;
    font-size: 1.125rem;
    letter-spacing: 0.1em;
  }

  .auth-btn {
    width: 100%;
  }

  .auth-error {
    margin-top: 0.75rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .auth-skip {
    text-align: center;
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
  }

  .skip-link {
    color: var(--text-tertiary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* OTP digits */
  .otp-inputs {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .otp-digit {
    width: 44px;
    height: 52px;
    text-align: center;
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: 0;
    border-radius: var(--radius-lg);
    border: 1.5px solid var(--border-light);
    background: var(--surface-input);
    color: var(--text-primary);
    caret-color: var(--color-primary);
    transition: border-color var(--transition-fast);
  }

  .otp-digit:focus {
    outline: none;
    border-color: var(--color-primary);
    background: var(--surface-elevated);
  }

  .resend-btn {
    width: 100%;
    background: none;
    border: none;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    cursor: pointer;
    padding: 0.5rem;
    margin-top: 0.5rem;
    transition: color var(--transition-fast);
  }

  .resend-btn:not(:disabled):hover {
    color: var(--color-primary);
  }

  .resend-btn:disabled {
    cursor: default;
  }

  .back-btn {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-secondary);
    padding: 0.25rem;
  }

  .auth-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .spinner {
    width: 28px;
    height: 28px;
    border: 3px solid var(--border-light);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
</style>
