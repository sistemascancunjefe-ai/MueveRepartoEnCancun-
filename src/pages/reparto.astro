---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Ruta Activa">

  <!-- Map container (full screen behind UI) -->
  <div id="map-container" style="position:fixed;inset:0;z-index:0;" aria-label="Mapa de ruta"></div>

  <!-- Main overlay UI -->
  <div class="reparto-ui">

    <!-- ── Status bar ── -->
    <div id="route-status-bar" class="status-bar stagger-item" aria-live="polite">
      <div class="status-content">
        <div class="status-left">
          <div id="gps-dot" class="gps-dot inactive" aria-hidden="true"></div>
          <span id="status-text" style="font-size:0.8125rem;font-weight:700;color:var(--text-secondary);">
            GPS inactivo
          </span>
        </div>
        <div class="status-right">
          <span id="stops-remaining" style="font-size:0.75rem;font-weight:700;color:var(--text-tertiary);">
            — paradas
          </span>
        </div>
      </div>
    </div>

    <!-- ── Next stop panel (top) ── -->
    <div id="next-panel" class="next-panel stagger-item" aria-label="Siguiente parada">
      <div id="next-panel-content">
        <p style="font-size:0.8125rem;color:var(--text-tertiary);text-align:center;padding:0.75rem 0;">
          Sin ruta activa — agrega paradas primero
        </p>
      </div>
    </div>

    <!-- ── Route list (bottom sheet) ── -->
    <div id="route-list-panel" class="route-list-panel">
      <div class="sheet-handle" style="cursor:pointer;" id="toggle-list-handle"></div>

      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
        <h2 style="font-size:0.9375rem;font-weight:800;color:var(--text-primary);margin:0;">
          Paradas de hoy
        </h2>
        <div style="display:flex;gap:0.375rem;">
          <button id="btn-optimize" class="btn-secondary btn-sm" aria-label="Optimizar orden de ruta">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3L13 9l4 4-6 6-4-4L1 21h22V3h-4zm-7.5 11.5l-4-4L13 5l4 4-5.5 5.5z"/></svg>
            Optimizar
          </button>
        </div>
      </div>

      <div id="route-stops-list" style="display:flex;flex-direction:column;gap:0.375rem;max-height:220px;overflow-y:auto;" class="no-scrollbar">
        <p style="font-size:0.8125rem;color:var(--text-tertiary);padding:0.5rem 0;">Cargando paradas...</p>
      </div>
    </div>

    <!-- ── FAB: Start / Stop route ── -->
    <div class="route-fab-area">
      <!-- Driving mode toggle (secondary FAB) -->
      <button id="btn-driving-mode" class="driving-fab" aria-label="Modo conducción"
              title="Modo conducción: pantalla simplificada">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.92 5.01C18.72 4.42 18.16 4 17.5 4h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-6.99zM6.5 15c-.83 0-1.5-.67-1.5-1.5S5.67 12 6.5 12s1.5.67 1.5 1.5S7.33 15 6.5 15zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 10l1.5-4.5h11L19 10H5z"/>
        </svg>
      </button>
      <button id="btn-toggle-route" class="route-fab" aria-label="Iniciar ruta" data-active="false">
        <svg id="fab-icon-start" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg id="fab-icon-stop" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="display:none;">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </button>
    </div>

  </div>
</MainLayout>

<!-- ── Driving Mode Overlay ──────────────────────────────────────────────── -->
<div id="driving-mode" style="display:none;position:fixed;inset:0;z-index:8000;
     background:#060A0E;flex-direction:column;align-items:center;justify-content:center;
     padding:1.5rem;text-align:center;">

  <!-- Close button -->
  <button id="dm-close"
          style="position:absolute;top:calc(env(safe-area-inset-top)+1rem);right:1rem;
                 background:rgba(255,255,255,0.06);border:1px solid #1E293B;
                 color:#64748B;border-radius:10px;padding:0.5rem 0.875rem;
                 font-size:0.8125rem;font-weight:700;cursor:pointer;">
    ✕ Salir
  </button>

  <!-- Stop number badge -->
  <div id="dm-stop-number"
       style="width:56px;height:56px;border-radius:50%;background:#00E8A2;
              color:#060A0E;font-size:1.375rem;font-weight:900;
              display:flex;align-items:center;justify-content:center;
              margin-bottom:1.25rem;box-shadow:0 0 0 8px rgba(0,232,162,0.12);">
    1
  </div>

  <!-- Address -->
  <p style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;
            color:#64748B;margin:0 0 0.5rem;">Siguiente parada</p>
  <h2 id="dm-address"
      style="font-size:1.5rem;font-weight:900;color:#E2E8F0;margin:0 0 0.5rem;
             letter-spacing:-0.03em;line-height:1.25;max-width:320px;">
    Cargando...
  </h2>
  <p id="dm-client" style="font-size:0.9375rem;color:#64748B;margin:0 0 2.5rem;"></p>

  <!-- Actions -->
  <div style="display:flex;flex-direction:column;gap:0.75rem;width:100%;max-width:320px;">
    <button id="dm-complete"
            style="width:100%;padding:1.25rem;background:linear-gradient(135deg,#00E8A2,#00C48C);
                   color:#060A0E;font-size:1.25rem;font-weight:900;border:none;
                   border-radius:16px;cursor:pointer;letter-spacing:-0.02em;
                   box-shadow:0 4px 20px rgba(0,232,162,0.3);">
      ✓ ENTREGADO
    </button>
    <div style="display:flex;gap:0.75rem;">
      <a id="dm-maps" href="#" target="_blank" rel="noopener noreferrer"
         style="flex:1;padding:0.875rem;background:rgba(59,130,246,0.12);
                border:1px solid rgba(59,130,246,0.25);color:#3B82F6;
                font-size:0.875rem;font-weight:800;border-radius:12px;
                text-decoration:none;text-align:center;">
        🗺️ Navegar
      </a>
      <a id="dm-whatsapp" href="#" target="_blank" rel="noopener noreferrer"
         style="flex:1;padding:0.875rem;background:rgba(37,211,102,0.12);
                border:1px solid rgba(37,211,102,0.25);color:#25D366;
                font-size:0.875rem;font-weight:800;border-radius:12px;
                text-decoration:none;text-align:center;">
        💬 Avisar
      </a>
    </div>
  </div>

  <!-- Remaining counter -->
  <p id="dm-remaining" style="font-size:0.8125rem;color:#475569;margin-top:2rem;font-weight:600;"></p>
</div>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />

<script>
  import { getStops, dbPut, dbPutMany, STORES } from '../lib/idb';
  import type { Stop } from '../lib/idb';
  import { requestNotificationPermission, notifyStopCompleted, notifyRouteStarted, notifyNearby } from '../lib/notifications';

  let map: any = null;
  let userMarker: any = null;
  let stopMarkers: any[] = [];
  let routePolyline: any = null;
  let watchId: number | null = null;
  let isRouteActive = false;
  let currentPosition: [number, number] | null = null;
  const CANCUN_CENTER: [number, number] = [21.1619, -86.8515];

  // ── Load Leaflet ──
  async function loadLeaflet() {
    if ((window as any).L) return (window as any).L;
    return new Promise<any>((resolve) => {
      const s = document.createElement('script');
      s.src = '/vendor/leaflet/leaflet.js';
      s.onload = () => resolve((window as any).L);
      document.head.appendChild(s);
    });
  }

  // ── Init map ──
  async function initMap() {
    const L = await loadLeaflet();
    const container = document.getElementById('map-container');
    if (!container || map) return;

    map = L.map(container, {
      center: CANCUN_CENTER,
      zoom: 13,
      zoomControl: false,
      attributionControl: false,
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; CartoDB',
      subdomains: 'abcd',
      maxZoom: 19,
    }).addTo(map);

    // Custom attribution (small)
    L.control.attribution({ position: 'bottomleft', prefix: '&copy; CartoDB' }).addTo(map);

    await renderStopMarkers(L);
  }

  // ── Render stop markers ──
  async function renderStopMarkers(L: any) {
    // Remove old markers
    stopMarkers.forEach(m => map.removeLayer(m));
    stopMarkers = [];
    if (routePolyline) { map.removeLayer(routePolyline); routePolyline = null; }

    const stops = await getStops();
    const pending = stops.filter(s => s.status !== 'completed' && s.lat && s.lng);

    if (pending.length === 0) {
      updateRouteList(stops);
      return;
    }

    // Draw markers
    pending.forEach((stop, i) => {
      const color = stop.priority === 'urgent' ? '#FF5A5F' : '#00E8A2';
      const icon = L.divIcon({
        className: '',
        html: `<div style="
          width:32px;height:32px;border-radius:50%;
          background:${color};
          border:3px solid #060A0E;
          display:flex;align-items:center;justify-content:center;
          font-size:11px;font-weight:900;color:#060A0E;
          box-shadow:0 2px 8px rgba(0,0,0,0.4);
          cursor:pointer;">${stop.order + 1}</div>`,
        iconSize: [32, 32],
        iconAnchor: [16, 16],
      });
      const marker = L.marker([stop.lat!, stop.lng!], { icon })
        .addTo(map)
        .bindPopup(`<strong>${stop.address}</strong>${stop.note ? `<br/>${stop.note}` : ''}`, {
          className: 'mr-popup',
        });
      stopMarkers.push(marker);
    });

    // Draw polyline route
    if (pending.length > 1) {
      const coords = pending.map(s => [s.lat!, s.lng!] as [number, number]);
      routePolyline = L.polyline(coords, {
        color: '#00E8A2',
        weight: 3,
        opacity: 0.7,
        dashArray: '8, 6',
      }).addTo(map);
    }

    // Fit bounds
    if (pending.length > 0) {
      const bounds = L.latLngBounds(pending.map(s => [s.lat!, s.lng!]));
      map.fitBounds(bounds, { padding: [60, 60] });
    }

    updateRouteList(stops);
    updateNextPanel(stops);
  }

  // ── Route list (bottom sheet) ──
  function updateRouteList(stops: Stop[]) {
    const el = document.getElementById('route-stops-list');
    if (!el) return;

    const remaining = document.getElementById('stops-remaining');
    const pendingCount = stops.filter(s => s.status !== 'completed').length;
    if (remaining) remaining.textContent = `${pendingCount} restantes`;

    if (stops.length === 0) {
      el.innerHTML = `<p style="font-size:0.8125rem;color:var(--text-tertiary);padding:0.5rem 0;text-align:center;">
        Sin paradas — <a href="/pedidos" style="color:var(--color-primary);">agregar aquí</a></p>`;
      return;
    }

    el.innerHTML = stops.map(s => `
      <div class="route-stop-row ${s.status === 'completed' ? 'done' : ''}">
        <div class="stop-number ${s.priority === 'urgent' ? 'urgent' : ''}" style="font-size:0.6875rem;width:1.5rem;height:1.5rem;">${s.order + 1}</div>
        <div style="flex:1;min-width:0;">
          <p style="font-size:0.8125rem;font-weight:600;color:var(--text-primary);margin:0;
            ${s.status === 'completed' ? 'text-decoration:line-through;color:var(--text-tertiary)' : ''};
            overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${s.address}</p>
        </div>
        ${s.status === 'completed'
          ? '<span class="badge badge-success" style="flex-shrink:0;">Listo</span>'
          : `<button class="stop-action-btn complete-btn" data-id="${s.id}" style="flex-shrink:0;" aria-label="Completar">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
             </button>`}
      </div>`).join('');

    el.querySelectorAll('.complete-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id!;
        const stop = stops.find(s => s.id === id);
        if (!stop) return;
        await dbPut(STORES.STOPS, { ...stop, status: 'completed', completedAt: Date.now() });
        const L = (window as any).L;
        if (L) await renderStopMarkers(L);
      });
    });
  }

  // ── Next stop panel ──
  function updateNextPanel(stops: Stop[]) {
    const next = stops.find(s => s.status === 'pending' || s.status === 'in_transit');
    const el = document.getElementById('next-panel-content');
    if (!el) return;

    if (!next) {
      el.innerHTML = `<p style="font-size:0.875rem;font-weight:700;color:var(--color-primary);text-align:center;padding:0.5rem 0;">
        ¡Ruta completada!</p>`;
      return;
    }

    el.innerHTML = `
      <div style="display:flex;align-items:flex-start;gap:0.625rem;">
        <div class="stop-number ${next.priority === 'urgent' ? 'urgent' : ''}">${next.order + 1}</div>
        <div style="flex:1;min-width:0;">
          <p style="font-size:0.625rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;
            color:var(--text-tertiary);margin:0 0 0.125rem;">Siguiente parada</p>
          <p style="font-size:0.9375rem;font-weight:700;color:var(--text-primary);margin:0;
            overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${next.address}</p>
          ${next.note ? `<p style="font-size:0.75rem;color:var(--text-secondary);margin:0.125rem 0 0;">${next.note}</p>` : ''}
        </div>
        ${next.lat && next.lng ? `
          <a href="https://maps.google.com/maps?daddr=${next.lat},${next.lng}"
             target="_blank" rel="noopener noreferrer"
             class="btn-primary btn-sm" style="flex-shrink:0;">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            Maps
          </a>` : ''}
      </div>`;
  }

  // ── GPS Tracking ──
  function startTracking() {
    if (!navigator.geolocation) return;
    const L = (window as any).L;

    const dot = document.getElementById('gps-dot');
    const statusText = document.getElementById('status-text');

    if (dot) dot.classList.replace('inactive', 'active');
    if (statusText) statusText.textContent = 'GPS activo — rastreando';

    window.dispatchEvent(new CustomEvent('mr:tracking-start'));

    watchId = navigator.geolocation.watchPosition(
      (pos) => {
        currentPosition = [pos.coords.latitude, pos.coords.longitude];
        if (!L || !map) return;

        if (!userMarker) {
          const icon = L.divIcon({
            className: '',
            html: `<div style="
              width:20px;height:20px;border-radius:50%;
              background:#00E8A2;border:3px solid white;
              box-shadow:0 0 0 4px rgba(0,232,162,0.25),0 2px 8px rgba(0,0,0,0.4);">
            </div>`,
            iconSize: [20, 20],
            iconAnchor: [10, 10],
          });
          userMarker = L.marker(currentPosition, { icon, zIndexOffset: 1000 }).addTo(map);
        } else {
          userMarker.setLatLng(currentPosition);
        }

        map.panTo(currentPosition, { animate: true });

        // Check proximity alert (non-blocking)
        getStops().then(stops => checkNearbyAlert(stops)).catch(() => {});
      },
      (err) => console.warn('[Reparto] GPS error:', err),
      { enableHighAccuracy: true, timeout: 10000, maximumAge: 5000 }
    );
  }

  function stopTracking() {
    if (watchId !== null) {
      navigator.geolocation.clearWatch(watchId);
      watchId = null;
    }
    const dot = document.getElementById('gps-dot');
    const statusText = document.getElementById('status-text');
    if (dot) dot.classList.replace('active', 'inactive');
    if (statusText) statusText.textContent = 'GPS inactivo';
    window.dispatchEvent(new CustomEvent('mr:tracking-stop'));
  }

  // ── Optimize route (nearest-neighbor greedy) ──
  async function optimizeRoute() {
    const allStops = await getStops();
    const completed = allStops.filter(s => s.status === 'completed');
    const pending   = allStops.filter(s => s.status !== 'completed');
    if (pending.length < 2) return;

    // Simple nearest-neighbor from current position or first pending stop with coords
    const firstWithCoords = pending.find(s => s.lat && s.lng);
    const start = currentPosition ??
      (firstWithCoords ? [firstWithCoords.lat!, firstWithCoords.lng!] as [number, number] : null);

    if (!start) {
      alert('Activa el GPS o agrega coordenadas a las paradas para optimizar la ruta.');
      return;
    }

    const unvisited = new Set(pending);
    const ordered: Stop[] = [];
    let current = start;

    while (unvisited.size > 0) {
      let nearest: Stop | null = null;
      let minDist = Infinity;

      for (const s of unvisited) {
        if (!s.lat || !s.lng) continue;
        const d = Math.hypot(s.lat - current[0], s.lng - current[1]);
        if (d < minDist) { minDist = d; nearest = s; }
      }

      // Stops without coords go at the end
      if (!nearest) {
        unvisited.forEach(s => ordered.push(s));
        break;
      }

      ordered.push(nearest);
      current = [nearest.lat!, nearest.lng!];
      unvisited.delete(nearest);
    }

    // Completed stays first (0..completed-1), optimized pending follows after
    const allOrdered: Stop[] = [
      ...completed.map((s, i) => ({ ...s, order: i })),
      ...ordered.map((s, i) => ({ ...s, order: completed.length + i })),
    ];

    await dbPutMany(STORES.STOPS, allOrdered);

    const L = (window as any).L;
    if (L) await renderStopMarkers(L);
  }

  // ── FAB toggle ──
  function toggleRoute() {
    const fab = document.getElementById('btn-toggle-route') as HTMLButtonElement;
    const iconStart = document.getElementById('fab-icon-start')!;
    const iconStop  = document.getElementById('fab-icon-stop')!;

    isRouteActive = !isRouteActive;
    fab.dataset.active = String(isRouteActive);
    fab.setAttribute('aria-label', isRouteActive ? 'Detener ruta' : 'Iniciar ruta');

    if (isRouteActive) {
      iconStart.style.display = 'none';
      iconStop.style.display  = 'block';
      fab.style.background    = 'var(--gradient-urgent)';
      fab.style.boxShadow     = '0 4px 20px rgba(255,90,95,0.4)';
      startTracking();
    } else {
      iconStart.style.display = 'block';
      iconStop.style.display  = 'none';
      fab.style.background    = 'var(--gradient-primary)';
      fab.style.boxShadow     = '0 4px 20px rgba(0,232,162,0.4)';
      stopTracking();
    }
  }

  // ── Toggle list handle ──
  function setupListToggle() {
    const panel = document.getElementById('route-list-panel')!;
    const handle = document.getElementById('toggle-list-handle')!;
    let expanded = true;

    handle.addEventListener('click', () => {
      expanded = !expanded;
      panel.style.transform = expanded ? 'translateY(0)' : 'translateY(calc(100% - 60px))';
    });
  }

  // ── Driving Mode ──────────────────────────────────────────────────────────
  let drivingActive = false;

  async function updateDrivingMode() {
    const overlay   = document.getElementById('driving-mode')!;
    const numEl     = document.getElementById('dm-stop-number')!;
    const addrEl    = document.getElementById('dm-address')!;
    const clientEl  = document.getElementById('dm-client')!;
    const mapsLink  = document.getElementById('dm-maps') as HTMLAnchorElement;
    const waLink    = document.getElementById('dm-whatsapp') as HTMLAnchorElement;
    const remaining = document.getElementById('dm-remaining')!;

    const stops  = await getStops();
    const next   = stops.find(s => s.status === 'pending' || s.status === 'in_transit');
    const pendingCount = stops.filter(s => s.status !== 'completed').length;

    if (!next) {
      addrEl.textContent  = '¡Todas completadas! 🎉';
      clientEl.textContent = '';
      numEl.textContent    = '✓';
      numEl.style.background = '#00E8A2';
      remaining.textContent = '';
      mapsLink.style.display = 'none';
      waLink.style.display   = 'none';
      return;
    }

    numEl.textContent   = String(next.order + 1);
    numEl.style.background = next.priority === 'urgent' ? '#FF5A5F' : '#00E8A2';
    addrEl.textContent  = next.address;
    clientEl.textContent = [next.clientName, next.clientPhone].filter(Boolean).join(' · ');
    remaining.textContent = `${pendingCount} parada${pendingCount !== 1 ? 's' : ''} restantes`;

    if (next.lat && next.lng) {
      mapsLink.href = `https://maps.google.com/maps?daddr=${next.lat},${next.lng}`;
      mapsLink.style.display = '';
    } else {
      mapsLink.style.display = 'none';
    }
    if (next.clientPhone) {
      const phone = next.clientPhone.replace(/\D/g, '');
      const msg   = encodeURIComponent(`Hola${next.clientName ? ` ${next.clientName}` : ''}! 🚚 Ya voy llegando a entregar tu pedido en ${next.address}.`);
      waLink.href = `https://wa.me/${phone}?text=${msg}`;
      waLink.style.display = '';
    } else {
      waLink.style.display = 'none';
    }
  }

  function openDrivingMode() {
    drivingActive = true;
    const overlay = document.getElementById('driving-mode')!;
    overlay.style.display = 'flex';
    updateDrivingMode();
    // Request notification permission on first driving mode use
    requestNotificationPermission();
  }

  function closeDrivingMode() {
    drivingActive = false;
    document.getElementById('driving-mode')!.style.display = 'none';
  }

  function setupDrivingMode() {
    document.getElementById('btn-driving-mode')?.addEventListener('click', openDrivingMode);
    document.getElementById('dm-close')?.addEventListener('click', closeDrivingMode);

    document.getElementById('dm-complete')?.addEventListener('click', async () => {
      const stops = await getStops();
      const next  = stops.find(s => s.status === 'pending' || s.status === 'in_transit');
      if (!next) return;

      await dbPut(STORES.STOPS, { ...next, status: 'completed', completedAt: Date.now() });

      const remaining = stops.filter(s => s.status !== 'completed').length - 1;
      await notifyStopCompleted(next.address, remaining);

      const L = (window as any).L;
      if (L) await renderStopMarkers(L);
      await updateDrivingMode();
    });
  }

  // ── Notification on GPS proximity ─────────────────────────────────────────
  let _lastNearbyNotif = 0;

  function checkNearbyAlert(stops: Stop[]) {
    if (!currentPosition) return;
    const next = stops.find(s => s.status === 'pending' || s.status === 'in_transit');
    if (!next?.lat || !next?.lng) return;

    const distKm = Math.hypot(next.lat - currentPosition[0], next.lng - currentPosition[1]) * 111;
    if (distKm <= 0.5 && Date.now() - _lastNearbyNotif > 120_000) {
      _lastNearbyNotif = Date.now();
      notifyNearby(next.address, distKm);
    }
  }

  // ── Init ──
  async function init() {
    await initMap();
    setupListToggle();
    setupDrivingMode();

    document.getElementById('btn-toggle-route')?.addEventListener('click', async () => {
      toggleRoute();
      if (isRouteActive) {
        const stops = await getStops();
        const pending = stops.filter(s => s.status !== 'completed').length;
        if (pending > 0) await notifyRouteStarted(pending);
      }
    });
    document.getElementById('btn-optimize')?.addEventListener('click', optimizeRoute);
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') init();
</script>

