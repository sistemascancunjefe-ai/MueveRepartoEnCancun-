  // -- Address Autocomplete State --
  let currentCoords: { lat: number, lng: number } | null = null;
  let autocompleteTimeout: number | undefined;
  let searchToken = 0;

  // Returns Nominatim results array, { serviceUnavailable: true } on 429/503, or [] on other errors.
  async function fetchSuggestions(query: string): Promise<any[] | { serviceUnavailable: true }> {
    try {
      // Add Cancun to query if not present to improve local results
      const q = query.toLowerCase().includes('cancun') || query.toLowerCase().includes('cancún')
        ? query
        : `${query}, Cancún`;

      const url = `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&addressdetails=1&limit=5`;
      const res = await fetch(url, {
        headers: { 'Accept-Language': 'es' }
      });
      if (res.status === 429 || res.status === 503) {
        return { serviceUnavailable: true };
      }
      if (!res.ok) throw new Error('Network response was not ok');
      return await res.json();
    } catch (err) {
      console.error('Geocoding error:', err);
      return [];
    }
  }

  function renderSuggestions(results: any[] | { serviceUnavailable: true }) {
    const container = document.getElementById('address-suggestions');
    const warning = document.getElementById('address-warning');
    if (!container || !warning) return;

    container.innerHTML = '';

    if (!Array.isArray(results) && (results as any).serviceUnavailable) {
      container.style.display = 'none';
      warning.textContent = '⚠️ Servicio de geocodificación no disponible. Inténtalo de nuevo más tarde.';
      warning.style.display = 'block';
      return;
    }

    const arr = results as any[];
    if (arr.length === 0) {
      container.style.display = 'none';
      warning.textContent = '⚠️ Dirección no encontrada. Se guardará sin mapa.';
      warning.style.display = 'block';
      return;
    }

    warning.style.display = 'none';

    arr.forEach(res => {
      const div = document.createElement('div');
      div.className = 'suggestion-item';
      div.setAttribute('role', 'option');
      div.tabIndex = 0;

      const primary = document.createElement('div');
      primary.className = 'suggestion-primary';
      const name = res.address?.road ? `${res.address.road}${res.address.house_number ? ' ' + res.address.house_number : ''}` : res.name;
      primary.textContent = name || res.display_name.split(',')[0];

      const secondary = document.createElement('div');
      secondary.className = 'suggestion-secondary';
      secondary.textContent = res.display_name;

      div.appendChild(primary);
      div.appendChild(secondary);

      div.addEventListener('click', () => {
        const input = document.getElementById('input-address') as HTMLTextAreaElement;
        input.value = res.display_name;
        currentCoords = { lat: parseFloat(res.lat), lng: parseFloat(res.lon) };
        container.style.display = 'none';
        updateSaveBtn();
      });

      // Also handle enter key for accessibility
      div.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          div.click();
        }
      });

      container.appendChild(div);
    });

    container.style.display = 'block';
  }

  function handleAddressInput(e: Event) {
    const val = (e.target as HTMLTextAreaElement).value.trim();
    const container = document.getElementById('address-suggestions');
    const warning = document.getElementById('address-warning');

    // Reset coords when typing manually
    currentCoords = null;

    if (!val || val.length < 3) {
      if (container) container.style.display = 'none';
      if (warning) warning.style.display = 'none';
      clearTimeout(autocompleteTimeout);
      return;
    }

    clearTimeout(autocompleteTimeout);
    autocompleteTimeout = window.setTimeout(async () => {
      const token = ++searchToken;
      const results = await fetchSuggestions(val);
      // Discard stale responses
      if (token !== searchToken) return;
      renderSuggestions(results);
    }, 500);
  }


  // ── Render ──
  async function renderStops() {
    allStops = await getStops();
    const filtered = filterStops(allStops, currentFilter);

    const countLabel = document.getElementById('stops-count-label');
    if (countLabel) {
      const done = allStops.filter(s => s.status === 'completed').length;
      countLabel.textContent = `${done}/${allStops.length} completadas`;
    }

    const listEl = document.getElementById('stops-list');
    if (!listEl) return;

    if (filtered.length === 0) {
      listEl.innerHTML = `
        <div class="empty-state">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" style="color:var(--text-tertiary)">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          <p style="font-size:0.875rem;font-weight:700;color:var(--text-secondary);margin:0;">
            ${currentFilter === 'all' ? 'Sin paradas aún' : 'Sin paradas en este filtro'}
          </p>
          ${currentFilter === 'all' ? '<button id="btn-add-first" class="btn-primary btn-md" style="margin-top:0.625rem;">+ Agregar parada</button>' : ''}
        </div>`;
      document.getElementById('btn-add-first')?.addEventListener('click', openAddSheet);
      return;
    }

    listEl.innerHTML = filtered.map((s, i) => `
      <div class="stop-card ${s.status === 'completed' ? 'completed' : ''} ${s.priority === 'urgent' ? 'priority-urgent' : 'priority-normal'}"
           data-id="${s.id}" data-order="${s.order}" draggable="true" role="button" tabindex="0" aria-label="Parada ${s.order + 1}: ${escapeHtml(s.address)}">

        <!-- Drag handle -->
        <div class="drag-handle" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color:var(--text-tertiary)">
            <path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
          </svg>
        </div>

        <!-- Number -->
        <div class="stop-number ${s.priority === 'urgent' ? 'urgent' : ''}">${s.order + 1}</div>
        <!-- Content -->
        <div style="flex:1;min-width:0;">
          <p class="stop-address">${escapeHtml(s.address)}</p>
          ${s.note ? `<p class="stop-meta">${escapeHtml(s.note)}</p>` : ''}
          ${s.clientName ? `<p class="stop-meta">${escapeHtml(s.clientName)}${s.clientPhone ? ' · ' + escapeHtml(s.clientPhone) : ''}</p>` : ''}
          <span id="geo-${s.id}" class="geo-indicator" style="display:none;align-items:center;gap:0.375rem;font-size:0.6875rem;color:var(--text-tertiary);font-weight:600;">
            <svg class="animate-spin" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
            Buscando coords...
          </span>
        </div>


        <!-- Right side -->
        <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.375rem;flex-shrink:0;">
          ${s.income ? `<span style="font-size:0.75rem;font-weight:800;color:var(--color-primary)">$${escapeHtml(s.income)}</span>` : ''}
          <span class="badge ${s.status === 'completed' ? 'badge-success' : s.priority === 'urgent' ? 'badge-urgent' : 'badge-pending'}">
            ${s.status === 'completed' ? 'Listo' : s.priority === 'urgent' ? 'Urgente' : 'Pend.'}
          </span>
        </div>

        <!-- Swipe actions (shown on long press or hover) -->
        <div class="stop-actions">
          ${s.status !== 'completed' ? `
            <button class="stop-action-btn complete-btn" data-id="${s.id}" aria-label="Completar parada" title="Completar">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
            </button>` : ''}
          <button class="stop-action-btn delete-btn" data-id="${s.id}" aria-label="Eliminar parada" title="Eliminar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
          </button>
        </div>
      </div>`).join('');

    // Bind events on stop cards
    listEl.querySelectorAll('.stop-card').forEach(card => {
      // Drag and Drop
      card.addEventListener('dragstart', (e: any) => {
        const target = e.currentTarget as HTMLElement;
        const index = target.dataset.index;
        if (index === null || index === undefined) return;
        e.dataTransfer.setData('text/plain', index);
        e.dataTransfer.effectAllowed = 'move';
        target.classList.add('dragging');
      });

      card.addEventListener('dragend', (e: any) => {
        const target = e.currentTarget as HTMLElement;
        target.classList.remove('dragging');
        // Clear any lingering drag-over states (e.g. cancelled drag)
        listEl.querySelectorAll('.stop-card.drag-over').forEach((el: Element) => {
          el.classList.remove('drag-over');
        });
      });

      card.addEventListener('dragover', (e: any) => {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        const target = e.currentTarget as HTMLElement;
        target.classList.add('drag-over');
      });

      card.addEventListener('dragleave', (e: any) => {
        const target = e.currentTarget as HTMLElement;
        target.classList.remove('drag-over');
      });

      card.addEventListener('drop', async (e: any) => {
        e.preventDefault();
        const target = e.currentTarget as HTMLElement;
        target.classList.remove('drag-over');

        const dragIndex = parseInt(e.dataTransfer.getData('text/plain'), 10);
        const dropIndex = parseInt(target.getAttribute('data-index')!, 10);

        if (dragIndex === dropIndex || isNaN(dragIndex) || isNaN(dropIndex)) return;

        // Identificamos el id del elemento donde se soltó ANTES de reordenar
        const targetId = filtered[dropIndex].id;

        // Reorder logic en filtered
        // When dragging downward the splice shifts indices, so adjust insertion point.
        // After the splice filtered.length = N-1; if dropIndex === filtered.length the
        // drop was on the last card, so skip the -1 adjustment to allow end-of-list placement.
        const item = filtered.splice(dragIndex, 1)[0];
        const insertAt = (dragIndex < dropIndex && dropIndex < filtered.length) ? dropIndex - 1 : dropIndex;
        filtered.splice(insertAt, 0, item);

        // Update orders to match new positions
        if (currentFilter === 'all') {
          const promises = filtered.map((stop, idx) => {
            stop.order = idx;
            return dbPut(STORES.STOPS, stop);
          });
          await Promise.all(promises);
        } else {
          // Si estamos filtrando, buscar su índice en allStops
          const allStopsItemIndex = allStops.findIndex(s => s.id === item.id);
          const allStopsTargetIndex = allStops.findIndex(s => s.id === targetId);

          if (allStopsItemIndex > -1 && allStopsTargetIndex > -1) {
            const removedItem = allStops.splice(allStopsItemIndex, 1)[0];
            // Adjust for direction shift, mirroring the filtered reorder adjustment.
            // After the splice allStops.length = M-1; if target index equals allStops.length
            // the drop was on the last item, so skip the -1 to allow end-of-list placement.
            const allInsertAt = (allStopsItemIndex < allStopsTargetIndex && allStopsTargetIndex < allStops.length) ? allStopsTargetIndex - 1 : allStopsTargetIndex;
            allStops.splice(allInsertAt, 0, removedItem);

            const promises = allStops.map((stop, idx) => {
              stop.order = idx;
              return dbPut(STORES.STOPS, stop);
            });
            await Promise.all(promises);
          }
        }

        await renderStops();
      });
      card.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.closest('.stop-action-btn')) return;
        const id = (card as HTMLElement).dataset.id!;
        openDetail(id);
      });
    });

    listEl.querySelectorAll('.complete-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id!;
        await completeStop(id);
        await renderStops();
      });
    });

    listEl.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        e.stopPropagation();
        const id = (btn as HTMLElement).dataset.id!;
        if (confirm('¿Eliminar esta parada?')) {
          await dbDelete(STORES.STOPS, id);
          await renderStops();
        }
      });
    });

    // ── Drag-and-drop reordering ──
    let dragSrcId: string | null = null;

    listEl.querySelectorAll<HTMLElement>('.stop-card').forEach(card => {
      card.addEventListener('dragstart', (e) => {
        dragSrcId = card.dataset.id!;
        card.classList.add('dragging');
        e.dataTransfer!.effectAllowed = 'move';
      });

      card.addEventListener('dragend', () => {
        card.classList.remove('dragging');
        listEl.querySelectorAll('.stop-card').forEach(c => c.classList.remove('drag-over'));
      });

      card.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.dataTransfer!.dropEffect = 'move';
        listEl.querySelectorAll('.stop-card').forEach(c => c.classList.remove('drag-over'));
        card.classList.add('drag-over');
      });

      card.addEventListener('dragleave', () => {
        card.classList.remove('drag-over');
      });

      card.addEventListener('drop', async (e) => {
        e.preventDefault();
        e.stopPropagation();
        const dropId = card.dataset.id!;
        if (!dragSrcId || dragSrcId === dropId) return;

        // Reordenar: intercambiar los valores de `order`
        const allCurrent = await getStops();
        const src  = allCurrent.find(s => s.id === dragSrcId);
        const dest = allCurrent.find(s => s.id === dropId);
        if (!src || !dest) return;

        const srcOrder  = src.order;
        const destOrder = dest.order;

        // Shift stops entre src y dest
        const updated: import('../lib/idb').Stop[] = allCurrent.map(s => {
          if (s.id === dragSrcId) return { ...s, order: destOrder };
          if (srcOrder < destOrder && s.order > srcOrder && s.order <= destOrder) return { ...s, order: s.order - 1 };
          if (srcOrder > destOrder && s.order >= destOrder && s.order < srcOrder) return { ...s, order: s.order + 1 };
          return s;
        });

        await Promise.all(updated.map(s => dbPut(STORES.STOPS, s)));
        dragSrcId = null;
        await renderStops();
      });
    });
  }

  function filterStops(stops: Stop[], filter: string): Stop[] {
    switch (filter) {
      case 'pending':   return stops.filter(s => s.status === 'pending' || s.status === 'in_transit');
      case 'urgent':    return stops.filter(s => s.priority === 'urgent' && s.status !== 'completed');
      case 'completed': return stops.filter(s => s.status === 'completed');
      default:          return stops;
    }
  }

