  // Extrae { lat, lng } de URLs de Google Maps, Waze, Apple Maps, etc.
  function parseCoordsFromMapUrl(url: string): { lat: number; lng: number } | null {
    const patterns = [
      // Google Maps: /maps/@LAT,LNG o /@LAT,LNG,zoom o ?q=LAT,LNG o &ll=LAT,LNG
      /[/@?&](-?\d+\.?\d*),(-?\d+\.?\d*)/,
      // Waze: ?ll=LAT,LNG o &ll=LAT,LNG
      /[?&]ll=(-?\d+\.?\d*),(-?\d+\.?\d*)/,
      // Apple Maps: ?ll=LAT,LNG
      /\?ll=(-?\d+\.?\d*),(-?\d+\.?\d*)/,
      // Genérico: lat=LAT&lng=LNG o lat=LAT&lon=LNG
      /lat=(-?\d+\.?\d*)&lon[g]?=(-?\d+\.?\d*)/i,
    ];
    for (const re of patterns) {
      const m = url.match(re);
      if (m) {
        const lat = parseFloat(m[1]);
        const lng = parseFloat(m[2]);
        // Validar rangos
        if (lat >= -90 && lat <= 90 && lng >= -180 && lng <= 180) {
          return { lat, lng };
        }
      }
    }
    return null;
  }

  let linkCoords: { lat: number; lng: number } | null = null;

  function getAddressValue(): string {
    switch (currentMode) {
      case 'text': return (document.getElementById('input-address') as HTMLTextAreaElement).value.trim();
      case 'coords': {
        const lat = (document.getElementById('input-lat') as HTMLInputElement).value.trim();
        const lng = (document.getElementById('input-lng') as HTMLInputElement).value.trim();
        return lat && lng ? `${lat}, ${lng}` : '';
      }
      case 'link': return (document.getElementById('input-link') as HTMLInputElement).value.trim();
      case 'qr': return scannedData.address || '';
      default: return '';
    }
  }

  function updateSaveBtn() {
    const btn = document.getElementById('btn-save-stop') as HTMLButtonElement;
    const addr = getAddressValue();
    if (btn) btn.disabled = !addr;
  }


  function showGeocodingIndicator(id: string, show: boolean) {
    const el = document.getElementById(`geo-${id}`);
    if (el) el.style.display = show ? 'flex' : 'none';
  }

  // ── Save stop ──
  async function saveStop() {
    const address = getAddressValue();
    if (!address) return;

    let finalLat: number | undefined;
    let finalLng: number | undefined;

    if (currentMode === 'text' && currentCoords) {
      finalLat = currentCoords.lat;
      finalLng = currentCoords.lng;
    } else if (currentMode === 'link') {
      const extracted = parseCoordsFromMapUrl(address);
      if (extracted) {
        finalLat = extracted.lat;
        finalLng = extracted.lng;
      }
    } else if (currentMode === 'qr' && scannedData.lat != null && scannedData.lng != null) {
      finalLat = scannedData.lat;
      finalLng = scannedData.lng;
    } else {
      const latStr = (document.getElementById('input-lat') as HTMLInputElement).value;
      const lngStr = (document.getElementById('input-lng') as HTMLInputElement).value;
      if (latStr) finalLat = parseFloat(latStr);
      if (lngStr) finalLng = parseFloat(lngStr);
    }

    const stop: import('../lib/idb').Stop = {
      id:          editingId ?? generateId(),
      address,
      lat:         finalLat,
      lng:         finalLng,
      priority:    selectedPriority,
      status:      'pending',
      note:        (document.getElementById('input-note') as HTMLInputElement).value.trim() || undefined,
      income:      parseFloat((document.getElementById('input-income') as HTMLInputElement).value) || undefined,
      clientName:  (document.getElementById('input-client-name') as HTMLInputElement).value.trim() || undefined,
      clientPhone: (document.getElementById('input-client-phone') as HTMLInputElement).value.trim() || undefined,
      order:       editingId ? (allStops.find(s => s.id === editingId)?.order ?? allStops.length) : allStops.length,
      createdAt:   Date.now(),
    };


    await dbPut(STORES.STOPS, stop);
    closeAddSheet();
    await renderStops();

    // Geocodificar en segundo plano SOLO en modo texto y si no tiene coords
    if (currentMode === 'text' && !stop.lat && !stop.lng) {
      showGeocodingIndicator(stop.id, true);
      const coords = await geocodeAddress(address);
      if (coords) {
        await dbPut(STORES.STOPS, { ...stop, lat: coords.lat, lng: coords.lng });
        await renderStops();  // Re-render con coords
      }
      showGeocodingIndicator(stop.id, false);
    }
  }


  // ── Detail Sheet ──
  function openDetail(id: string) {
    const stop = allStops.find(s => s.id === id);
    if (!stop) return;

    const overlay = document.getElementById('detail-overlay')!;
    const sheet   = document.getElementById('detail-sheet')!;
    const content = document.getElementById('detail-content')!;

    content.innerHTML = `
      <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:1rem;">
        <div class="stop-number ${stop.priority === 'urgent' ? 'urgent' : ''}" style="font-size:1rem;width:2rem;height:2rem;">${stop.order + 1}</div>
        <div style="flex:1;">
          <p style="font-size:1rem;font-weight:700;color:var(--text-primary);margin:0 0 0.125rem;">${escapeHtml(stop.address)}</p>
          ${stop.note ? `<p style="font-size:0.8125rem;color:var(--text-secondary);margin:0;">${escapeHtml(stop.note)}</p>` : ''}
        </div>
        <button id="detail-close" style="background:none;border:none;cursor:pointer;color:var(--text-tertiary);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>
        </button>
      </div>

      <div style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:1.25rem;">
        ${stop.clientName ? `<div class="detail-row"><span>Cliente</span><strong>${escapeHtml(stop.clientName)}</strong></div>` : ''}
        ${stop.clientPhone ? `<div class="detail-row"><span>Teléfono</span><a href="tel:${escapeHtml(stop.clientPhone)}" style="color:var(--color-primary);font-weight:700;">${escapeHtml(stop.clientPhone)}</a></div>` : ''}
        ${stop.income ? `<div class="detail-row"><span>Ingreso</span><strong style="color:var(--color-primary)">$${escapeHtml(stop.income)}</strong></div>` : ''}
        <div class="detail-row"><span>Estado</span>
          <span class="badge ${stop.status === 'completed' ? 'badge-success' : stop.priority === 'urgent' ? 'badge-urgent' : 'badge-pending'}">
            ${stop.status === 'completed' ? 'Completada' : stop.priority === 'urgent' ? 'Urgente' : 'Pendiente'}
          </span>
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        ${stop.status !== 'completed' ? `
          <button id="detail-complete" data-id="${stop.id}" class="btn-primary btn-lg" style="width:100%;">
            Marcar como entregada
          </button>` : ''}
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
          ${stop.clientPhone ? `
            <a href="https://wa.me/${stop.clientPhone.replace(/\D/g,'')}?text=Tu+pedido+est%C3%A1+en+camino+🚚"
               target="_blank" rel="noopener noreferrer" class="btn-whatsapp" style="justify-content:center;">
              WhatsApp
            </a>` : `<div></div>`}
          <a href="/enviar?id=${stop.id}" class="btn-secondary btn-md" style="text-align:center;">
            Notificar
          </a>
        </div>
        <button id="detail-delete" data-id="${stop.id}" class="btn-danger btn-md" style="width:100%;">
          Eliminar parada
        </button>
      </div>`;

    overlay.classList.add('open');
    sheet.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');

    document.getElementById('detail-close')?.addEventListener('click', closeDetail);
    document.getElementById('detail-complete')?.addEventListener('click', async () => {
      await completeStop(stop.id);
      closeDetail();
      await renderStops();
    });
    document.getElementById('detail-delete')?.addEventListener('click', async () => {
      if (confirm('¿Eliminar esta parada?')) {
        await dbDelete(STORES.STOPS, stop.id);
        closeDetail();
        await renderStops();
      }
    });
  }

  function closeDetail() {
    document.getElementById('detail-overlay')!.classList.remove('open');
    document.getElementById('detail-sheet')!.classList.remove('open');
    document.getElementById('detail-overlay')!.setAttribute('aria-hidden', 'true');
  }

  // ── Priority buttons ──
  function updatePriorityBtns() {
    document.querySelectorAll('.priority-btn').forEach(btn => {
      const p = (btn as HTMLElement).dataset.priority;
      btn.classList.toggle('active', p === selectedPriority);
      (btn as HTMLButtonElement).setAttribute('aria-pressed', String(p === selectedPriority));
    });
  }

  // ── Mode tabs ──
  function switchMode(mode: string) {

    if (currentMode === 'ocr' && mode !== 'ocr') {
      cleanupOcr();
    }
    currentMode = mode;
    document.querySelectorAll('.mode-tab').forEach(t => {
      t.classList.toggle('active', (t as HTMLElement).dataset.mode === mode);
      (t as HTMLButtonElement).setAttribute('aria-pressed', String((t as HTMLElement).dataset.mode === mode));
    });
    ['text','coords','ocr','link','qr'].forEach(m => {
      const panel = document.getElementById(`mode-${m}`)!;
      panel.style.display = m === mode ? 'block' : 'none';
    });
    updateSaveBtn();
  }


  // ── OCR Logic ──
  let tesseractWorker: any = null;
  let currentPreviewUrl: string | null = null;
  let ocrRunId = 0;

  async function destroyOcrWorker() {
    const worker = tesseractWorker;
    if (worker) {
      tesseractWorker = null;
      await worker.terminate();
    }
  }
  async function geocodePendingStops() {
    if (!navigator.onLine) return;
    const stops = await getStops();
    const pending = stops.filter(s => !s.lat && !s.lng && s.status !== 'completed');
    for (const stop of pending) {
      const coords = await geocodeAddress(stop.address);
      if (coords) {
        await dbPut(STORES.STOPS, { ...stop, lat: coords.lat, lng: coords.lng });
      }
    }
    if (pending.length > 0) {
      await renderStops();
    }
  }

  // ── Init ──
  function init() {
    // QR Scanner events
    document.getElementById('btn-start-qr')?.addEventListener('click', startQRScanner);
    document.getElementById('btn-stop-qr')?.addEventListener('click', stopQRScanner);
    document.getElementById('btn-apply-scan')?.addEventListener('click', applyScanResult);
    document.getElementById('btn-discard-scan')?.addEventListener('click', () => {
      document.getElementById('scan-result')!.style.display = 'none';
      scannedData = {};
    });

    // Sub-tabs QR vs OCR
    document.querySelectorAll('.scan-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const mode = (tab as HTMLElement).dataset.scan!;
        document.querySelectorAll('.scan-tab').forEach(t => {
          t.classList.toggle('active', t === tab);
          (t as HTMLButtonElement).setAttribute('aria-pressed', String(t === tab));
        });
        const qrPanel  = document.getElementById('scan-qr-panel')!;
        const ocrPanel = document.getElementById('scan-ocr-panel')!;
        qrPanel.style.display  = mode === 'qr'  ? 'block' : 'none';
        ocrPanel.style.display = mode === 'ocr' ? 'block' : 'none';
        if (mode === 'ocr') stopQRScanner();  // Detener cámara QR si se cambia a OCR
      });
    });

    // OCR: tomar foto
    document.getElementById('btn-take-photo')?.addEventListener('click', async () => {
      try {
        const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
        // Capturar frame
        const video = document.createElement('video');
        video.srcObject = stream;
        await video.play();
        const canvas = document.createElement('canvas');
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        canvas.getContext('2d')!.drawImage(video, 0, 0);
        stream.getTracks().forEach(t => t.stop());
        const dataUrl = canvas.toDataURL('image/jpeg', 0.85);

        // Mostrar preview
        const img = document.getElementById('ocr-preview-img') as HTMLImageElement;
        const placeholder = document.getElementById('ocr-placeholder')!;
        img.src = dataUrl;
        img.style.display = 'block';
        placeholder.style.display = 'none';

        await runOCR(dataUrl);
      } catch {
        alert('No se pudo acceder a la cámara.');
      }
    });

    // OCR: subir archivo de galería
    document.getElementById('file-ocr')?.addEventListener('change', async (e) => {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;

      const img = document.getElementById('ocr-preview-img') as HTMLImageElement;
      const placeholder = document.getElementById('ocr-placeholder')!;
      img.src = URL.createObjectURL(file);
      img.style.display = 'block';
      placeholder.style.display = 'none';

      await runOCR(file);
    });

    document.getElementById('btn-add-stop')?.addEventListener('click', openAddSheet);
    document.getElementById('btn-add-first')?.addEventListener('click', openAddSheet);
    document.getElementById('close-sheet')?.addEventListener('click', closeAddSheet);
    document.getElementById('add-overlay')?.addEventListener('click', closeAddSheet);
    document.getElementById('detail-overlay')?.addEventListener('click', closeDetail);
    document.getElementById('paywall-close')?.addEventListener('click', closePaywall);
    document.getElementById('paywall-overlay')?.addEventListener('click', closePaywall);

    document.getElementById('btn-save-stop')?.addEventListener('click', saveStop);
    // Filter tabs
    document.querySelectorAll('.filter-tab').forEach(tab => {
      tab.addEventListener('click', async () => {
        currentFilter = (tab as HTMLElement).dataset.filter!;
        document.querySelectorAll('.filter-tab').forEach(t => {
          t.classList.toggle('active', t === tab);
          (t as HTMLElement).setAttribute('aria-selected', String(t === tab));
        });
        await renderStops();
      });
    });

    // Mode tabs
    document.querySelectorAll('.mode-tab').forEach(tab => {
      tab.addEventListener('click', () => switchMode((tab as HTMLElement).dataset.mode!));
    });

    // Priority buttons
    document.querySelectorAll('.priority-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedPriority = (btn as HTMLElement).dataset.priority as 'normal' | 'urgent';
        updatePriorityBtns();
      });
    });

    // Address input → enable save
    document.getElementById('input-address')?.addEventListener('input', (e) => {
      updateSaveBtn();
      handleAddressInput(e);
    });

    // Close suggestions when clicking outside
    document.addEventListener('click', (e) => {
      const container = document.getElementById('address-suggestions');
      const input = document.getElementById('input-address');
      if (container && input && e.target !== input && !container.contains(e.target as Node)) {
        container.style.display = 'none';
      }
    });
    document.getElementById('input-lat')?.addEventListener('input', updateSaveBtn);
    document.getElementById('input-lng')?.addEventListener('input', updateSaveBtn);
    document.getElementById('input-link')?.addEventListener('input', updateSaveBtn);

    // GPS button
    document.getElementById('btn-use-gps')?.addEventListener('click', () => {
      if (!navigator.geolocation) return;
      navigator.geolocation.getCurrentPosition(pos => {
        (document.getElementById('input-lat') as HTMLInputElement).value = pos.coords.latitude.toFixed(6);
        (document.getElementById('input-lng') as HTMLInputElement).value = pos.coords.longitude.toFixed(6);
        updateSaveBtn();
      });
    });


    // OCR tab events
    const ocrInputFile = document.getElementById('ocr-input-file') as HTMLInputElement;
    const btnTakePhoto = document.getElementById('btn-ocr-take-photo');
    const previewContainer = document.getElementById('ocr-preview-container');
    const previewImg = document.getElementById('ocr-preview-img') as HTMLImageElement;
    const btnExtract = document.getElementById('btn-ocr-extract');
    const progressContainer = document.getElementById('ocr-progress-container');
    const resultContainer = document.getElementById('ocr-result-container');

    if (btnTakePhoto) {
      btnTakePhoto.addEventListener('click', () => {
        ocrInputFile?.click();
      });
    }

    if (ocrInputFile) {
      ocrInputFile.addEventListener('change', (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file) {
          // Revoke any previously tracked blob URL before creating a new one
          if (currentPreviewUrl) {
            URL.revokeObjectURL(currentPreviewUrl);
          }
          const url = URL.createObjectURL(file);
          currentPreviewUrl = url;
          if (previewImg) {
            previewImg.src = url;
            previewImg.onload = () => {
              URL.revokeObjectURL(url);
              if (currentPreviewUrl === url) currentPreviewUrl = null;
            };
            previewImg.onerror = () => {
              URL.revokeObjectURL(url);
              if (currentPreviewUrl === url) currentPreviewUrl = null;
            };
          }
          if (previewContainer) previewContainer.style.display = 'block';
          if (btnExtract) btnExtract.style.display = 'block';
          if (progressContainer) progressContainer.style.display = 'none';
          if (resultContainer) resultContainer.style.display = 'none';
        }
      });
    }

    if (btnExtract) {
      btnExtract.addEventListener('click', () => {
        extractOcrText();
      });
    }

    const btnUseAddress = document.getElementById('btn-ocr-use-address');
    if (btnUseAddress) {
      btnUseAddress.addEventListener('click', () => {
        const text = (document.getElementById('ocr-textarea-result') as HTMLTextAreaElement).value;
        if (!text) return;

        const lines = text.split('\n').map(l => l.trim()).filter(l => l.length > 0);

        // Extract phone number (e.g., 10 digits)
        const phoneRegex = /(?:\+?52)?(?:\s*-)?(?:\d[\s-]?){10}/;
        const phoneMatch = text.match(phoneRegex);
        if (phoneMatch) {
            const inputPhone = document.getElementById('input-client-phone') as HTMLInputElement;
            if (inputPhone) inputPhone.value = phoneMatch[0].replace(/[\s-]/g, '').slice(-10);
        }

        // Try to identify Name and Address heuristically
        // E.g., if line 1 has no numbers it might be the name.
        // If line 2 has numbers and street names (Calle, Av, SM, Mz, Lt), it's the address.
        let potentialAddress = "";
        let potentialName = "";
        let notes = "";

        for (const line of lines) {
           const lower = line.toLowerCase();
           if (lower.includes('calle') || lower.includes('av') || lower.includes('sm') || lower.includes('mz') || lower.includes('lt') || lower.includes('mza') || lower.includes('lote') || lower.includes('c.')) {
              if (potentialAddress.length > 0) potentialAddress += " " + line;
              else potentialAddress = line;
           } else if (line.length > 2 && line.length < 40 && !phoneRegex.test(line) && potentialName === "") {
              // Could be name if no address keywords and no phone number
              potentialName = line;
           } else {
              if (!line.match(phoneRegex)) {
                  notes += line + " ";
              }
           }
        }

        if (!potentialAddress) {
            // If heuristics fail, just use the first non-phone line as address
            potentialAddress = lines.find(l => !l.match(phoneRegex) && l !== potentialName) || text;
        }

        const inputAddress = document.getElementById('input-address') as HTMLTextAreaElement;
        if (inputAddress) {
            inputAddress.value = potentialAddress.trim();
            // Trigger input event for validation
            inputAddress.dispatchEvent(new Event('input'));
        }

        const inputName = document.getElementById('input-client-name') as HTMLInputElement;
        if (inputName && potentialName) {
            inputName.value = potentialName.trim();
        }

        const inputNote = document.getElementById('input-note') as HTMLInputElement;
        if (inputNote && notes.trim().length > 0) {
            inputNote.value = notes.trim().substring(0, 100);
        }

        switchMode('text');
      });
    }


    renderStops();
    setTimeout(() => geocodePendingStops(), 2000);
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') init();
</script>

