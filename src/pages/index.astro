---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Cargando" hideNav={true}>
  <div class="splash">
    <!-- Animated grid background -->
    <div class="splash-grid" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="dots" width="32" height="32" patternUnits="userSpaceOnUse">
            <circle cx="1" cy="1" r="1" fill="rgba(0,232,162,0.12)"/>
          </pattern>
        </defs>
        <rect fill="url(#dots)" width="100%" height="100%"/>
      </svg>
    </div>

    <!-- Glow orb -->
    <div class="splash-orb" aria-hidden="true"></div>

    <!-- Main content -->
    <div class="splash-content">
      <!-- Logo icon -->
      <div class="splash-icon-wrap" aria-hidden="true">
        <svg width="56" height="56" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L21 7V17L12 22L3 17V7L12 2Z"
                stroke="#00E8A2" stroke-width="1.8" stroke-linejoin="round"/>
          <path d="M12 2L12 22" stroke="#00E8A2" stroke-width="1.2" opacity="0.45"/>
          <path d="M3 7L12 12L21 7" stroke="#00E8A2" stroke-width="1.5" opacity="0.6"/>
        </svg>
      </div>

      <!-- Brand -->
      <h1 class="splash-title">
        Mueve<span class="splash-accent">Reparto</span>
      </h1>
      <p class="splash-tagline">Tu jornada. Optimizada.</p>

      <!-- Loader -->
      <div class="splash-loader" aria-label="Cargando..." role="status">
        <div class="loader-track">
          <div class="loader-bar"></div>
        </div>
        <span class="loader-text">Iniciando...</span>
      </div>
    </div>

    <!-- Version -->
    <span class="splash-version">v2.0.0</span>
  </div>
</MainLayout>

<script>
  import { navigate } from 'astro:transitions/client';

  // Splash: 2s then go to /home
  setTimeout(() => {
    navigate('/home');
  }, 2000);
</script>

<style>
  .splash {
    position: fixed;
    inset: 0;
    background: #060A0E;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .splash-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.7;
  }

  /* Radial glow in brand green */
  .splash-orb {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 232, 162, 0.12) 0%, transparent 70%);
    pointer-events: none;
    animation: orb-pulse 3s ease-in-out infinite;
  }

  @keyframes orb-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1);   opacity: 0.8; }
    50%       { transform: translate(-50%, -50%) scale(1.15); opacity: 1; }
  }

  .splash-content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    animation: content-in 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes content-in {
    from { opacity: 0; transform: translateY(24px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .splash-icon-wrap {
    width: 88px;
    height: 88px;
    border-radius: 22px;
    background: rgba(0, 232, 162, 0.08);
    border: 1px solid rgba(0, 232, 162, 0.18);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
    animation: icon-bounce 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
    box-shadow: 0 0 40px rgba(0, 232, 162, 0.15);
  }

  @keyframes icon-bounce {
    from { opacity: 0; transform: scale(0.6); }
    to   { opacity: 1; transform: scale(1); }
  }

  .splash-title {
    font-family: "Inter", sans-serif;
    font-size: 2.25rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: #F0F6FC;
    margin: 0;
    line-height: 1;
  }

  .splash-accent {
    color: #00E8A2;
  }

  .splash-tagline {
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(240, 246, 252, 0.45);
    letter-spacing: 0.04em;
    margin: 0;
    text-transform: uppercase;
    font-size: 0.75rem;
  }

  .splash-loader {
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: 160px;
  }

  .loader-track {
    width: 100%;
    height: 3px;
    background: rgba(0, 232, 162, 0.12);
    border-radius: 2px;
    overflow: hidden;
  }

  .loader-bar {
    height: 100%;
    background: linear-gradient(90deg, #00E8A2, #00C98A);
    border-radius: 2px;
    animation: loader-fill 2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes loader-fill {
    from { width: 0%; }
    to   { width: 100%; }
  }

  .loader-text {
    font-size: 0.6875rem;
    color: rgba(240, 246, 252, 0.35);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .splash-version {
    position: absolute;
    bottom: max(env(safe-area-inset-bottom), 1.5rem);
    font-size: 0.625rem;
    font-family: monospace;
    letter-spacing: 0.12em;
    color: rgba(240, 246, 252, 0.2);
    text-transform: uppercase;
  }
</style>
