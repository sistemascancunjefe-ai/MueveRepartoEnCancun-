---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Panel de Control">
  <div class="dash animate-in">
    <!-- ── Header: Saludo + Fecha ── -->
    <header class="stagger-item dash-greeting">
      <div>
        <p id="greeting-text" class="greeting-sub">...</p>
        <h1 id="greeting-date" class="greeting-title">...</h1>
      </div>
      <div id="today-date-badge" class="dash-date-badge">...</div>
    </header>

    <!-- ── Hero: Progreso + KPIs ── -->
    <div class="stagger-item dash-hero">
      <div class="progress-section">
        <svg class="progress-svg" viewBox="0 0 100 100">
          <circle class="progress-ring-track" cx="50" cy="50" r="48" fill="none" stroke-width="4" />
          <circle id="progress-ring" class="progress-ring-fill" cx="50" cy="50" r="48" fill="none" stroke-width="4"
                  stroke-dasharray="301.59" stroke-dashoffset="301.59" />
        </svg>
        <div class="progress-center">
          <div style="display:flex;align-items:baseline;">
            <span id="progress-done" class="progress-num">0</span>
            <span class="progress-sep">/</span>
            <span id="progress-total" class="progress-total">0</span>
          </div>
          <span class="progress-unit">Paradas</span>
        </div>
      </div>

      <div class="metrics-col">
        <div class="metric-card">
          <div class="metric-icon" style="background:rgba(0,232,162,0.1);color:var(--color-primary)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"/></svg>
          </div>
          <span id="m-done" class="metric-value">0</span>
          <span class="metric-label">Completas</span>
        </div>
        <div class="metric-card">
          <div class="metric-icon" style="background:rgba(255,90,95,0.1);color:#FF5A5F">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M13 14h-2V9h2v5zm0 4h-2v-2h2v2zM1 21h22L12 2 1 21z"/></svg>
          </div>
          <span id="m-urgent" class="metric-value">0</span>
          <span class="metric-label">Urgentes</span>
        </div>
        <div class="metric-card">
          <div class="metric-icon" style="background:rgba(0,232,162,0.1);color:var(--color-primary)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
          </div>
          <span id="m-income" class="metric-value">$0</span>
          <span class="metric-label">Ingreso</span>
        </div>
      </div>
    </div>

    <!-- ── Siguiente parada ── -->
    <div class="stagger-item section-block">
      <p class="section-label">Siguiente parada</p>
      <div id="next-stop-card" class="next-stop-card delivery-card">
        <div class="next-stop-empty">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--text-tertiary)">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
          <span style="font-size:0.875rem;color:var(--text-tertiary);font-weight:600;">Sin paradas pendientes</span>
          <a href="/pedidos" class="btn-primary btn-sm" style="margin-top:0.5rem;">Agregar parada</a>
        </div>
      </div>
    </div>

    <!-- ── Acciones rápidas ── -->
    <div class="stagger-item section-block">
      <p class="section-label">Acciones rápidas</p>
      <div class="quick-actions">
        <a href="/pedidos" class="quick-btn" data-tooltip="Tus pedidos">
          <div class="quick-btn-icon" style="background:rgba(0,232,162,0.1);color:var(--color-primary)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          </div>
          <span>Paradas</span>
        </a>
        <a href="/reparto" class="quick-btn" data-tooltip="Optimiza y entrega">
          <div class="quick-btn-icon" style="background:rgba(59,130,246,0.1);color:#3B82F6">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.56 3.91c.39.39.39 1.02 0 1.41l-4.83 4.83-2.37-2.37 1.42-1.42c.39-.39 1.02-.39 1.41 0l.71.71 3.25-3.16c.39-.39 1.02-.39 1.41 0zM4 17.5V21h3.5l10.31-10.32-3.5-3.5L4 17.5z"/></svg>
          </div>
          <span>Ruta</span>
        </a>
        <a href="/enviar" class="quick-btn" data-tooltip="Avisa al cliente">
          <div class="quick-btn-icon" style="background:rgba(37,211,102,0.1);color:#25D366">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
          </div>
          <span>Notificar</span>
        </a>
        <a href="/metricas" class="quick-btn" data-tooltip="Ver productividad">
          <div class="quick-btn-icon" style="background:rgba(245,158,11,0.1);color:#F59E0B">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"/></svg>
          </div>
          <span>Métricas</span>
        </a>

        <a href="/gasolina" class="quick-btn" data-tooltip="Control de gastos">
          <div class="quick-btn-icon" style="background:rgba(239,68,68,0.1);color:#EF4444">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.77 7.23l.01-.01-3.72-3.72L15 4.56l2.11 2.11c-.94.36-1.61 1.26-1.61 2.33 0 1.38 1.12 2.5 2.5 2.5.36 0 .69-.08 1-.21v7.21c0 .55-.45 1-1 1s-1-.45-1-1V14c0-1.1-.9-2-2-2h-1V5c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v16h10v-7.5h1.5v5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V9c0-.69-.28-1.32-.73-1.77zM12 10H6V5h6v5zm6 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/></svg>
          </div>
          <span>Gasolina</span>
        </a>
      </div>
    </div>

    <!-- ── Entregas del día (lista) ── -->
    <div class="stagger-item section-block">
      <p class="section-label">Paradas de hoy</p>
      <div id="stops-list" class="stops-preview">
        <div class="stops-empty-hint" style="font-size:0.8125rem;color:var(--text-tertiary);text-align:center;padding:1.5rem 0;">
          Aún no hay paradas para hoy
        </div>
      </div>
    </div>

  </div>
</MainLayout>

<script>
  import { getTodayStats, getStops, getNextStop } from '../lib/idb';
  import type { Stop } from '../lib/idb';
  import { getRepartidorName } from '../lib/session';

  async function loadDashboard() {
    // ── Greeting ──
    const now = new Date();
    const hour = now.getHours();
    const greeting = hour < 12 ? 'Buenos días' : hour < 19 ? 'Buenas tardes' : 'Buenas noches';
    const repartidorName = getRepartidorName();

    const greetEl = document.getElementById('greeting-text');
    if (greetEl) greetEl.textContent = repartidorName ? `${greeting}, ${repartidorName}` : greeting;

    const dateEl = document.getElementById('greeting-date');
    const badgeEl = document.getElementById('today-date-badge');
    const dateStr = now.toLocaleDateString('es-MX', { weekday: 'long', day: 'numeric', month: 'long' });
    const shortDate = now.toLocaleDateString('es-MX', { day: 'numeric', month: 'short' });
    if (dateEl) dateEl.textContent = dateStr.charAt(0).toUpperCase() + dateStr.slice(1);
    if (badgeEl) badgeEl.textContent = shortDate;

    // ── Stats ──
    const stats = await getTodayStats();
    const { completed, total, income, urgent } = stats;

    document.getElementById('m-done')!.textContent   = String(completed);
    document.getElementById('m-urgent')!.textContent = String(urgent);
    document.getElementById('m-income')!.textContent = `$${income.toFixed(0)}`;
    document.getElementById('progress-done')!.textContent  = String(completed);
    document.getElementById('progress-total')!.textContent = String(total);

    // Progress ring
    const circumference = 301.59;
    const pct = total > 0 ? completed / total : 0;
    const offset = circumference * (1 - pct);
    const ring = document.getElementById('progress-ring');
    if (ring) ring.setAttribute('stroke-dashoffset', String(offset));

    // ── Next stop ──
    const nextStop = await getNextStop();
    const card = document.getElementById('next-stop-card');
    if (card) {
      if (nextStop) {
        card.innerHTML = `
          <div class="next-stop-content ${nextStop.priority === 'urgent' ? 'priority-urgent' : 'priority-normal'}">
            <div style="display:flex;align-items:flex-start;gap:0.75rem;">
              <div class="stop-number ${nextStop.priority === 'urgent' ? 'urgent' : ''}">${nextStop.order + 1}</div>
              <div style="flex:1;min-width:0;">
                <p class="stop-address">${nextStop.address}</p>
                ${nextStop.note ? `<p class="stop-meta">${nextStop.note}</p>` : ''}
                ${nextStop.clientName ? `<p class="stop-meta">${nextStop.clientName}${nextStop.clientPhone ? ' · ' + nextStop.clientPhone : ''}</p>` : ''}
              </div>
              ${nextStop.priority === 'urgent' ? '<span class="badge badge-urgent">Urgente</span>' : ''}
            </div>
            <div style="display:flex;gap:0.5rem;margin-top:0.75rem;">
              <a href="/reparto" class="btn-primary btn-sm" style="flex:1;text-align:center;">
                Navegar
              </a>
              <a href="/enviar?id=${nextStop.id}" class="btn-secondary btn-sm" style="flex:1;text-align:center;">
                Notificar
              </a>
            </div>
          </div>`;
      }
    }

    // ── Stops preview list ──
    const stops = await getStops();
    const listEl = document.getElementById('stops-list');
    if (listEl && stops.length > 0) {
      listEl.innerHTML = stops.slice(0, 5).map((s: Stop) => `
        <div class="stop-preview-row ${s.status === 'completed' ? 'done' : ''}">
          <div class="stop-number ${s.priority === 'urgent' ? 'urgent' : ''}" style="font-size:0.6875rem;">${s.order + 1}</div>
          <div style="flex:1;min-width:0;">
            <p class="stop-address" style="font-size:0.875rem;">${s.address}</p>
          </div>
          <span class="badge ${s.status === 'completed' ? 'badge-success' : s.priority === 'urgent' ? 'badge-urgent' : 'badge-pending'}">
            ${s.status === 'completed' ? 'Listo' : s.priority === 'urgent' ? 'Urgente' : 'Pendiente'}
          </span>
        </div>`).join('') +
        (stops.length > 5 ? `<a href="/pedidos" style="display:block;text-align:center;font-size:0.8125rem;color:var(--color-primary);font-weight:700;padding:0.75rem 0;">Ver todas (${stops.length})</a>` : '');
    }
  }

  // Load on every page visit
  document.addEventListener('astro:page-load', loadDashboard);
  if (document.readyState !== 'loading') loadDashboard();
</script>

<style>
  .dash { max-width: 480px; margin: 0 auto; }

  /* Greeting */
  .dash-greeting {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .greeting-sub {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-weight: 600;
    text-transform: capitalize;
    margin: 0 0 0.125rem;
  }

  .greeting-title {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.2;
  }

  .dash-date-badge {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.625rem;
    border-radius: var(--radius-full);
    background: var(--surface-elevated);
    border: 1px solid var(--border-light);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-secondary);
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.25rem;
  }

  /* Hero: ring + metrics */
  .dash-hero {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    padding: 1.125rem;
    margin-bottom: 1.25rem;
  }

  /* Progress Ring */
  .progress-section {
    position: relative;
    flex-shrink: 0;
  }

  .progress-svg {
    width: 110px;
    height: 110px;
    display: block;
  }

  .progress-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .progress-num {
    font-size: 1.625rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    line-height: 1;
  }

  .progress-sep {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    line-height: 1;
    margin: 0 1px;
  }

  .progress-total {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text-tertiary);
    line-height: 1;
  }

  .progress-unit {
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
    margin-top: 2px;
  }

  /* Metrics column */
  .metrics-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .metric-card {
    background: var(--surface-elevated);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .metric-icon {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .metric-value {
    font-size: 1.0625rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    flex: 1;
  }

  .metric-label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
  }

  /* Section block */
  .section-block {
    margin-bottom: 1.25rem;
  }

  .section-label {
    font-size: 0.625rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.625rem;
  }

  .section-label::after {
    content: '';
    height: 1px;
    flex: 1;
    background: var(--border-light);
  }

  /* Next stop card */
  .next-stop-card {
    border-radius: var(--radius-lg);
  }

  .next-stop-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem;
  }

  .next-stop-content {
    padding: 0 0 0 0.75rem;
  }

  /* Quick actions */
  .quick-actions {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.375rem;
  }

  .quick-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    padding: 0.75rem 0.125rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 0.625rem;
    font-weight: 700;
    transition: all var(--transition-fast);
    -webkit-tap-highlight-color: transparent;
    text-align: center;
    min-width: 0;
  }

  .quick-btn:hover {
    border-color: var(--color-primary);
    color: var(--text-primary);
  }

  .quick-btn:active { transform: scale(0.94); }

  .quick-btn-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .quick-btn span {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    width: 100%;
    padding: 0 2px;
  }

  /* Stops preview */
  .stops-preview {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .stop-preview-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.625rem 0.75rem;
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
  }

  .stop-preview-row.done {
    opacity: 0.5;
  }

  .stop-preview-row.done .stop-address {
    text-decoration: line-through;
  }
</style>
