---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Gasolina">
  <div class="fuel-page px-4 pt-4">

    <div class="stagger-item fuel-header">
      <div>
        <h1 class="page-title">Gasolina</h1>
        <p class="page-sub" id="fuel-subtitle">Registra cada llenado y controla tu rendimiento</p>
      </div>
      <button id="btn-add-fuel" class="btn-primary btn-sm" aria-label="Registrar llenado">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
        </svg>
        Registrar
      </button>
    </div>

    <!-- KPIs -->
    <div class="stagger-item kpi-grid" id="kpi-grid">
      <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(245,158,11,0.1);color:#F59E0B;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.77 7.23l.01-.01-3.72-3.72L15 4.56l2.11 2.11c-.94.36-1.61 1.26-1.61 2.33 0 1.38 1.12 2.5 2.5 2.5.36 0 .69-.08 1-.21v7.21c0 .55-.45 1-1 1s-1-.45-1-1V14c0-1.1-.9-2-2-2h-1V5c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v16h10v-7.5h1.5v5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V9c0-.69-.28-1.32-.73-1.77zM12 10H6V5h6v5zm6 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z"/></svg>
        </div>
        <span class="kpi-value" id="kpi-total-spent">$0</span>
        <span class="kpi-label">Total gastado</span>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(0,232,162,0.1);color:#00E8A2;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M13 2.05v2.02c3.95.49 7 3.85 7 7.93 0 3.21-1.81 6-4.72 7.28L13 17v5h5l-1.22-1.22C19.91 19.07 22 15.76 22 12c0-5.18-3.94-9.45-9-9.95zM11 2.05C5.95 2.55 2 6.82 2 12c0 3.76 2.09 7.07 5.22 8.78L6 22h5v-5l-2.28 2.28C7.81 18 6 15.21 6 12c0-4.08 3.05-7.44 7-7.93V2.05z"/></svg>
        </div>
        <span class="kpi-value" id="kpi-efficiency">— km/L</span>
        <span class="kpi-label">Rendimiento</span>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(59,130,246,0.1);color:#3B82F6;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
        </div>
        <span class="kpi-value" id="kpi-cost-per-stop">$—</span>
        <span class="kpi-label">Costo/parada</span>
      </div>
      <div class="kpi-card">
        <div class="kpi-icon" style="background:rgba(255,90,95,0.1);color:#FF5A5F;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z"/></svg>
        </div>
        <span class="kpi-value" id="kpi-last-fill">—</span>
        <span class="kpi-label">Último llenado</span>
      </div>
    </div>

    <!-- Last fill progress bar -->
    <div class="stagger-item" id="range-section" style="display:none;">
      <p class="section-label">Autonomía estimada</p>
      <div class="autonomy-card glass-card">
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.625rem;">
          <span style="font-size:0.875rem;font-weight:700;color:var(--text-secondary);">Desde último llenado</span>
          <span id="range-km" style="font-size:1.125rem;font-weight:900;color:var(--color-primary);">—</span>
        </div>
        <div style="width:100%;height:10px;background:var(--border-light);border-radius:99px;overflow:hidden;">
          <div id="range-bar" style="height:100%;width:0%;background:var(--gradient-primary);
               border-radius:99px;transition:width 0.8s cubic-bezier(0.16,1,0.3,1);"></div>
        </div>
        <div style="display:flex;justify-content:space-between;margin-top:0.375rem;">
          <span style="font-size:0.6875rem;color:var(--text-tertiary);">0 km</span>
          <span id="range-max" style="font-size:0.6875rem;color:var(--text-tertiary);">— km estimados</span>
        </div>
      </div>
    </div>

    <!-- History -->
    <div class="stagger-item">
      <p class="section-label">Historial de llenados</p>
      <div id="fuel-list" style="display:flex;flex-direction:column;gap:0.5rem;">
        <p style="font-size:0.8125rem;color:var(--text-tertiary);text-align:center;padding:2rem 0;">
          Sin registros todavía.<br>
          <button onclick="document.getElementById('btn-add-fuel').click()"
                  style="color:var(--color-primary);font-weight:700;background:none;border:none;cursor:pointer;font-size:0.8125rem;margin-top:0.375rem;">
            Registrar primer llenado →
          </button>
        </p>
      </div>
    </div>

  </div>
</MainLayout>

<!-- Add Fuel Sheet -->
<div id="fuel-overlay" class="bottom-sheet-overlay" aria-hidden="true"></div>
<div id="fuel-sheet" class="bottom-sheet" role="dialog" aria-label="Registrar llenado">
  <div class="sheet-handle"></div>
  <h2 style="font-size:1.125rem;font-weight:800;color:var(--text-primary);margin:0 0 1.25rem;">
    Registrar llenado
  </h2>

  <div style="display:flex;flex-direction:column;gap:0.75rem;">
    <div>
      <label style="font-size:0.75rem;font-weight:700;color:var(--text-tertiary);
                    text-transform:uppercase;letter-spacing:0.06em;display:block;margin-bottom:0.375rem;">
        Litros cargados *
      </label>
      <input id="fuel-liters" type="number" min="1" step="0.5" class="input" placeholder="Ej: 15.5" />
    </div>
    <div>
      <label style="font-size:0.75rem;font-weight:700;color:var(--text-tertiary);
                    text-transform:uppercase;letter-spacing:0.06em;display:block;margin-bottom:0.375rem;">
        Precio por litro (MXN) *
      </label>
      <input id="fuel-price" type="number" min="1" step="0.5" class="input" placeholder="Ej: 23.50" />
    </div>
    <div>
      <label style="font-size:0.75rem;font-weight:700;color:var(--text-tertiary);
                    text-transform:uppercase;letter-spacing:0.06em;display:block;margin-bottom:0.375rem;">
        Odómetro km (opcional — mejora precisión)
      </label>
      <input id="fuel-odometer" type="number" min="0" step="1" class="input" placeholder="Ej: 45320" />
    </div>
    <div>
      <label style="font-size:0.75rem;font-weight:700;color:var(--text-tertiary);
                    text-transform:uppercase;letter-spacing:0.06em;display:block;margin-bottom:0.375rem;">
        Nota (opcional)
      </label>
      <input id="fuel-note" type="text" class="input" placeholder="Ej: Pemex Av. López Portillo" maxlength="60" />
    </div>

    <!-- Total preview -->
    <div id="fuel-total-preview" style="display:none;padding:0.625rem 0.875rem;
         background:rgba(0,232,162,0.06);border:1px solid rgba(0,232,162,0.15);
         border-radius:10px;text-align:center;">
      <span style="font-size:0.75rem;color:var(--text-tertiary);">Total a pagar: </span>
      <strong id="fuel-total-val" style="font-size:1rem;color:var(--color-primary);">$0</strong>
    </div>
  </div>

  <button id="fuel-save" class="btn-primary btn-lg" style="width:100%;margin-top:1.25rem;">
    Guardar llenado
  </button>
</div>

<script>
  import { dbPut, dbGetAll, dbDelete, generateId, STORES } from '../lib/idb';
  import type { FuelLog } from '../lib/idb';

  let logs: FuelLog[] = [];

  // ── KPI Calculations ──────────────────────────────────────────────────────
  function calcKpis(fuelLogs: FuelLog[]) {
    if (fuelLogs.length === 0) return null;
    const sorted = [...fuelLogs].sort((a, b) => b.date - a.date);
    const totalSpent = fuelLogs.reduce((s, l) => s + l.totalCost, 0);
    const totalLiters = fuelLogs.reduce((s, l) => s + l.liters, 0);

    // Efficiency: only calculable with odometer readings
    let efficiency: number | null = null;
    const withOdo = sorted.filter(l => l.odometer != null);
    if (withOdo.length >= 2) {
      const kmDiff = withOdo[0].odometer! - withOdo[withOdo.length - 1].odometer!;
      const litDiff = withOdo.slice(0, -1).reduce((s, l) => s + l.liters, 0);
      if (litDiff > 0 && kmDiff > 0) efficiency = kmDiff / litDiff;
    }

    const last = sorted[0];
    const daysSince = Math.floor((Date.now() - last.date) / 86400000);
    const lastFillText = daysSince === 0 ? 'Hoy' : daysSince === 1 ? 'Ayer' : `Hace ${daysSince} días`;

    return { totalSpent, totalLiters, efficiency, last, lastFillText };
  }

  // ── Render KPIs ────────────────────────────────────────────────────────────
  async function loadAndRender() {
    logs = await dbGetAll<FuelLog>(STORES.FUEL);
    logs.sort((a, b) => b.date - a.date);

    const kpis = calcKpis(logs);

    if (kpis) {
      document.getElementById('kpi-total-spent')!.textContent =
        `$${kpis.totalSpent.toFixed(0)}`;
      document.getElementById('kpi-efficiency')!.textContent =
        kpis.efficiency ? `${kpis.efficiency.toFixed(1)} km/L` : '— km/L';
      document.getElementById('kpi-last-fill')!.textContent = kpis.lastFillText;

      // Cost per stop: rough estimate — 20 stops/tank
      const avgStops = 20;
      const costPerStop = kpis.efficiency
        ? (kpis.last.liters * kpis.last.pricePerLiter) / (kpis.last.liters * kpis.efficiency / 20)
        : null;
      document.getElementById('kpi-cost-per-stop')!.textContent =
        costPerStop ? `$${costPerStop.toFixed(1)}` : '$—';

      // Autonomy bar
      if (kpis.efficiency && kpis.last) {
        const rangeSection = document.getElementById('range-section')!;
        rangeSection.style.display = 'block';
        const maxKm = kpis.last.liters * kpis.efficiency;
        document.getElementById('range-max')!.textContent = `${maxKm.toFixed(0)} km estimados`;
        document.getElementById('range-km')!.textContent = `${maxKm.toFixed(0)} km`;
        // Rough consumed: days since fill × 30 km/day
        const daysSince = Math.floor((Date.now() - kpis.last.date) / 86400000);
        const consumed = Math.min(daysSince * 30, maxKm);
        const remainPct = Math.max(0, ((maxKm - consumed) / maxKm) * 100);
        document.getElementById('range-bar')!.style.width = `${remainPct}%`;
        (document.getElementById('range-bar') as HTMLElement).style.background =
          remainPct < 20 ? 'var(--color-urgent, #FF5A5F)' : 'var(--gradient-primary)';
      }
    }

    renderList();
  }

  // ── Render List ────────────────────────────────────────────────────────────
  function renderList() {
    const el = document.getElementById('fuel-list')!;
    if (logs.length === 0) {
      el.innerHTML = `<p style="font-size:0.8125rem;color:var(--text-tertiary);text-align:center;padding:2rem 0;">
        Sin registros todavía.<br>
        <button onclick="document.getElementById('btn-add-fuel').click()"
                style="color:var(--color-primary);font-weight:700;background:none;border:none;cursor:pointer;font-size:0.8125rem;margin-top:0.375rem;">
          Registrar primer llenado →
        </button>
      </p>`;
      return;
    }

    el.innerHTML = logs.map(log => {
      const d = new Date(log.date).toLocaleDateString('es-MX', { day: 'numeric', month: 'short', year: 'numeric' });
      return `
        <div class="fuel-row">
          <div style="display:flex;align-items:flex-start;justify-content:space-between;">
            <div style="flex:1;min-width:0;">
              <p style="font-size:0.875rem;font-weight:700;color:var(--text-primary);margin:0 0 0.125rem;">
                ${log.liters.toFixed(1)} L — <span style="color:var(--color-primary);">$${log.totalCost.toFixed(0)}</span>
              </p>
              <p style="font-size:0.75rem;color:var(--text-tertiary);margin:0;">
                ${d} · $${log.pricePerLiter.toFixed(2)}/L
                ${log.odometer ? ` · ${log.odometer.toLocaleString()} km` : ''}
              </p>
              ${log.note ? `<p style="font-size:0.75rem;color:var(--text-secondary);margin:0.125rem 0 0;">${log.note}</p>` : ''}
            </div>
            <button data-delete="${log.id}"
                    style="padding:0.375rem;background:transparent;border:none;
                           color:var(--text-tertiary);cursor:pointer;flex-shrink:0;"
                    aria-label="Eliminar registro">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/>
              </svg>
            </button>
          </div>
        </div>`;
    }).join('');

    el.querySelectorAll('[data-delete]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = (btn as HTMLElement).dataset.delete!;
        if (!confirm('¿Eliminar este registro?')) return;
        await dbDelete(STORES.FUEL, id);
        await loadAndRender();
      });
    });
  }

  // ── Sheet logic ────────────────────────────────────────────────────────────
  function openSheet() {
    const overlay = document.getElementById('fuel-overlay')!;
    const sheet   = document.getElementById('fuel-sheet')!;
    overlay.classList.add('open');
    sheet.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
    (document.getElementById('fuel-liters') as HTMLInputElement).focus();
  }

  function closeSheet() {
    const overlay = document.getElementById('fuel-overlay')!;
    const sheet   = document.getElementById('fuel-sheet')!;
    overlay.classList.remove('open');
    sheet.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    // Clear inputs
    ['fuel-liters','fuel-price','fuel-odometer','fuel-note'].forEach(id => {
      (document.getElementById(id) as HTMLInputElement).value = '';
    });
    (document.getElementById('fuel-total-preview') as HTMLElement).style.display = 'none';
  }

  function updateTotalPreview() {
    const liters = parseFloat((document.getElementById('fuel-liters') as HTMLInputElement).value) || 0;
    const price  = parseFloat((document.getElementById('fuel-price') as HTMLInputElement).value)  || 0;
    const preview = document.getElementById('fuel-total-preview')!;
    const valEl   = document.getElementById('fuel-total-val')!;
    if (liters > 0 && price > 0) {
      preview.style.display = 'block';
      valEl.textContent = `$${(liters * price).toFixed(2)}`;
    } else {
      preview.style.display = 'none';
    }
  }

  async function saveFuel() {
    const liters = parseFloat((document.getElementById('fuel-liters') as HTMLInputElement).value);
    const price  = parseFloat((document.getElementById('fuel-price') as HTMLInputElement).value);
    if (!liters || !price) {
      (window as any).showToast?.('Completa litros y precio.', 'warning');
      return;
    }
    const odometerStr = (document.getElementById('fuel-odometer') as HTMLInputElement).value;
    const log: FuelLog = {
      id:            generateId(),
      date:          Date.now(),
      liters,
      pricePerLiter: price,
      totalCost:     liters * price,
      odometer:      odometerStr ? parseInt(odometerStr, 10) : undefined,
      note:          (document.getElementById('fuel-note') as HTMLInputElement).value.trim() || undefined,
    };
    await dbPut(STORES.FUEL, log);
    closeSheet();
    await loadAndRender();
    (window as any).showToast?.('Llenado registrado ✅', 'success');
  }

  // ── Init ──
  function init() {
    loadAndRender();

    document.getElementById('btn-add-fuel')?.addEventListener('click', openSheet);
    document.getElementById('fuel-overlay')?.addEventListener('click', closeSheet);
    document.getElementById('fuel-save')?.addEventListener('click', saveFuel);
    document.getElementById('fuel-liters')?.addEventListener('input', updateTotalPreview);
    document.getElementById('fuel-price')?.addEventListener('input', updateTotalPreview);
  }

  document.addEventListener('astro:page-load', init);
  if (document.readyState !== 'loading') init();
</script>

<style>
  .fuel-page { max-width: 480px; margin: 0 auto; padding-bottom: 2rem; }

  .fuel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .page-title {
    font-size: 1.375rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin: 0 0 0.125rem;
  }

  .page-sub {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    font-weight: 500;
    margin: 0;
  }

  .section-label {
    font-size: 0.625rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.625rem;
    margin-top: 1.25rem;
  }

  .section-label::after {
    content: '';
    height: 1px;
    flex: 1;
    background: var(--border-light);
  }

  /* KPI grid */
  .kpi-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .kpi-card {
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 0.875rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .kpi-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.125rem;
  }

  .kpi-value {
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1;
  }

  .kpi-label {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-tertiary);
  }

  .autonomy-card { margin-bottom: 0.25rem; }

  /* Fuel history rows */
  .fuel-row {
    background: var(--surface-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    padding: 0.875rem;
  }
</style>
