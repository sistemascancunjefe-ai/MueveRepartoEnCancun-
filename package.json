{
  "name": "cancunmueve-pwa",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "tar": "^7.5.4",
      "axios": "^1.7.9"
    }
  },
  "scripts": {
    "optimize-json": "node scripts/optimize-json.mjs",
    "dev": "pnpm run optimize-json && astro dev",
    "dev:network": "pnpm run optimize-json && astro dev --host",
    "build": "pnpm optimize-json && node scripts/build-wasm.mjs && node scripts/check-wasm.cjs && astro build",
    "build:wasm": "node scripts/build-wasm.mjs",
    "astro": "astro",
    "lint": "eslint .",
    "preview": "astro preview",
    "test": "vitest",
    "check-wasm": "node scripts/check-wasm.cjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.0",
    "@astrojs/rss": "^4.0.5",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.0",
    "@tailwindcss/typography": "^0.5.10",
    "@types/node": "^24.10.1",
    "astro": "^5.16.15",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "fuse.js": "^7.0.0",
    "idb": "^8.0.3",
    "postcss": "^8.5.6",
    "serve": "^14.2.5",
    "sharp": "^0.33.2",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.0",
    "vite": "^6.3.1",
    "wasm-pack": "^0.14.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@eslint/js": "^9.39.1",
    "cheerio": "^1.2.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "http-server": "^14.1.1",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.0.1"
  }
}
