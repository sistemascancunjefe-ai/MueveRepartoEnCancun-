# .env.example — Variables de entorno para Mueve Reparto
# Copia este archivo a .env y completa los valores
# NUNCA subas .env al repositorio

# === REQUERIDAS EN PRODUCCIÓN ===

# Versión de Node.js para Render
NODE_VERSION=20.10.0

# === REQUERIDAS CON BACKEND (P3+) ===

# URL del API backend Rust (Render Web Service)
PUBLIC_API_URL=https://mueve-reparto-api.onrender.com

# Para desarrollo local con backend activo:
# PUBLIC_API_URL=http://localhost:8080

# === FUTURAS (P5 — Auth OTP) ===
# Descomenta cuando se implemente autenticación

# Twilio / proveedor OTP
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# JWT Secret (generar con: openssl rand -hex 32)
# JWT_SECRET=your_jwt_secret_here
