# .env.example — Variables de entorno para Mueve Reparto
# Copia este archivo a .env y completa los valores
# NUNCA subas .env al repositorio

# === REQUERIDAS EN PRODUCCIÓN ===

# Versión de Node.js para Render
NODE_VERSION=20.10.0

# === FUTURAS (P3 — Backend) ===
# Descomenta cuando se implemente el backend en P3

# URL del API backend Rust
# PUBLIC_API_URL=https://api.muevereparto.sistemascancunjefe.com

# === FUTURAS (P5 — Auth OTP) ===
# Descomenta cuando se implemente autenticación

# Twilio / proveedor OTP
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# JWT Secret (generar con: openssl rand -hex 32)
# JWT_SECRET=your_jwt_secret_here
