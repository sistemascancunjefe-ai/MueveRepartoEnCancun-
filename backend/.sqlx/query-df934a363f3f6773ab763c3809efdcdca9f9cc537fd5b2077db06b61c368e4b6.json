{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT id, user_id::text as \"user_id!\", date, deliveries, 0::INT4 AS \"total!\",\n               income, 0.0::FLOAT8 AS distance_km, 0::INT4 AS duration_min\n        FROM daily_stats\n        WHERE user_id = $1\n          AND date >= CURRENT_DATE - ($2::integer * INTERVAL '1 day')\n        ORDER BY date DESC\n        ",
